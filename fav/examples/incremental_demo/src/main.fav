import "incremental"

public fn main(ctx: AppCtx) -> Unit {
    bind rows <- incremental.run_since("demo_run", |since|
        collect {
            yield Map.set(Map.set((), "id", "1"), "since", since);
            ()
        }
    )
    ctx.io.println($"Fetched {List.length(rows)} row(s)");
    bind meta <- incremental.meta("demo_run")
    ctx.io.println($"Checkpoint updated at {meta.updated_at}");
}
