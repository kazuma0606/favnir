// runes/llm/client.fav — LLM クライアント (v9.6.0)
// Anthropic Claude / OpenAI 統一 API。エフェクトは !Llm。
//
// 環境変数:
//   LLM_PROVIDER  = "anthropic"（デフォルト）| "openai"
//   LLM_MODEL     = モデル名（省略時: claude-opus-4-6 / gpt-4o）
//   ANTHROPIC_API_KEY / OPENAI_API_KEY

// complete — シングルターンプロンプトを LLM に送信
public fn complete(prompt: String) -> Result<String, String> !Llm {
    Llm.complete_raw(prompt)
}

// chat — マルチターン会話を LLM に送信
// messages は [{role: "user"|"assistant", content: "..."}] の JSON 文字列
public fn chat(messages_json: String) -> Result<String, String> !Llm {
    Llm.chat_raw(messages_json)
}

// extract<T> — プロンプトとデータから型 T の構造体を抽出
public fn extract<T>(prompt: String, data: String) -> Result<T, String> !Llm {
    match Llm.extract_raw(type_name_of<T>(), prompt, data) {
        Err(e) => Result.err(e)
        Ok(raw) =>
            match Json.parse_raw(raw) {
                Err(e) => Result.err(String.concat("llm.extract: ", e))
                Ok(parsed) =>
                    match Schema.adapt_one(parsed, type_name_of<T>()) {
                        Err(_) => Result.err("llm.extract: schema error")
                        Ok(v)  => Result.ok(v)
                    }
            }
    }
}
