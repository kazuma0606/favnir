import "json"

type Config = {
    host: String
    port: Int
}

public fn main(ctx: AppCtx) -> Unit {
    bind text <- File.read("config.json")
    bind result <- json.parse<Config>(text)
    match result {
        Ok(config) => {
            ctx.io.println($"Connecting to {config.host}:{config.port}");
            ctx.io.println(json.write<Config>(config))
        }
        Err(err) => {
            ctx.io.println($"JSON error: {Debug.show(err)}")
        }
    }
}
