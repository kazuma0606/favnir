type UserRow = {
    value: Int
}

abstract stage ParseInput: String -> UserRow
abstract stage RenderRow: UserRow -> String

abstract seq Pipeline<Row> {
    parse: String -> Row
    render: Row -> String
}

stage ParseCsvUser: String -> UserRow = |text| {
    UserRow { value: 7 }
}

stage RenderUser: UserRow -> String = |row| {
    "user"
}

seq RenderPipeline = Pipeline<UserRow> {
    parse <- ParseCsvUser
    render <- RenderUser
}

public fn main() -> String {
    RenderPipeline("input")
}
