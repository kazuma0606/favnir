// runes/postgres/types.fav — Postgres 型定義 (v25.1.0)

// PgConfig — 接続設定（接続文字列として表現）
// 例: "host=localhost port=5432 user=postgres password=postgres dbname=mydb sslmode=disable"
type PgConfig(String)

// PgConn — アクティブ接続（内部は接続文字列）
type PgConn(String)

// PoolConfig — コネクションプール設定
// 例: "max_size=10 host=localhost port=5432 user=postgres password=postgres dbname=mydb"
type PoolConfig(String)
