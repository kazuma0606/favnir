type UserRow = {
    value: Int
}

abstract stage ParseRow: Int -> UserRow
abstract stage SaveRow: UserRow -> String

abstract seq DataPipeline<Row> {
    parse: Int -> Row
    save: Row -> String
}

stage ParseUser: Int -> UserRow = |x| {
    UserRow { value: x }
}

stage SaveUser: UserRow -> String = |row| {
    "saved"
}

seq UserImport = DataPipeline<UserRow> {
    parse <- ParseUser
    save <- SaveUser
}

public fn main() -> String {
    UserImport(1)
}
