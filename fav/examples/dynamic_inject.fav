type UserRow = {
    value: Int
}

abstract stage Parse<Row>: String -> Row

abstract seq Pipeline<Row> {
    parse: Parse<Row>
    render: Row -> String
}

stage ParseUser: String -> UserRow = |text| {
    UserRow { value: 7 }
}

stage RenderUser: UserRow -> String = |row| {
    "user"
}

seq UserPipeline = Pipeline<UserRow> {
    parse <- ParseUser
    render <- RenderUser
}

public fn main() -> String {
    UserPipeline("input")
}
