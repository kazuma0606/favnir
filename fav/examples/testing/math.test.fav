// math.test.fav — TypeScript-style test file for math utilities
// Run with: fav test examples/math.test.fav

fn abs(n: Int) -> Int {
    if n < 0 { 0 - n } else { n }
}

fn clamp(n: Int, lo: Int, hi: Int) -> Int {
    if n < lo { lo } else { if n > hi { hi } else { n } }
}

fn factorial(n: Int) -> Int {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

test "abs positive" {
    assert_eq(abs(5), 5)
}

test "abs negative" {
    assert_eq(abs(0 - 7), 7)
}

test "abs zero" {
    assert_eq(abs(0), 0)
}

test "clamp below lo" {
    assert_eq(clamp(0 - 5, 0, 10), 0)
}

test "clamp above hi" {
    assert_eq(clamp(99, 0, 10), 10)
}

test "clamp in range" {
    assert_eq(clamp(5, 0, 10), 5)
}

test "factorial 5" {
    assert_eq(factorial(5), 120)
}

test "factorial 1" {
    assert_eq(factorial(1), 1)
}
