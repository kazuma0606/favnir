// ValidOrder: assert_schema<ValidOrder> を通過した注文（名目型による安全保証）
type ValidOrder    = { id: Int, amount: Float, status: String }
type EnrichedOrder = { id: Int, amount: Float, status: String, region: String }

fn run(order: ValidOrder) -> Result<EnrichedOrder, String> {
  Result.ok({ id: order.id, amount: order.amount, status: order.status, region: "us-east-1" })
}
