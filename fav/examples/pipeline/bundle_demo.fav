type UserRow = {
    value: Int
}

stage ParseUser: String -> UserRow = |text| {
    UserRow { value: 1 }
}

stage RenderUser: UserRow -> String = |row| {
    "bundle-ok"
}

stage DeadStep: String -> String = |text| {
    "dead"
}

seq MainFlow =
    ParseUser
    |> RenderUser

public fn main() -> String {
    MainFlow("input")
}
