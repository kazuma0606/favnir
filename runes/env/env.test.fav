// env.test.fav — Env Rune tests (v4.7.0)

import rune "env"

test "get missing key returns default" {
    assert(env.get("__FAV_ENV_TEST_47_MISSING_A__", "default_val") == "default_val")
}

test "get_opt missing key returns None" {
    assert(Option.is_none(env.get_opt("__FAV_ENV_TEST_47_MISSING_B__")))
}

test "require missing key returns Err" {
    match env.require("__FAV_ENV_TEST_47_MISSING_C__") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "ENV_MISSING"))
    }
}

test "get_int missing key returns default" {
    assert(env.get_int("__FAV_ENV_TEST_47_MISSING_D__", 42) == 42)
}

test "require_int missing key returns Err" {
    match env.require_int("__FAV_ENV_TEST_47_MISSING_E__") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "ENV_MISSING"))
    }
}

test "get_bool missing key returns default false" {
    assert(env.get_bool("__FAV_ENV_TEST_47_MISSING_F__", false) == false)
}

test "get_bool missing key returns default true" {
    assert(env.get_bool("__FAV_ENV_TEST_47_MISSING_G__", true) == true)
}

test "require_bool missing key returns Err" {
    match env.require_bool("__FAV_ENV_TEST_47_MISSING_H__") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "ENV_MISSING"))
    }
}

test "load_dotenv_or_ignore nonexistent file succeeds" {
    env.load_dotenv_or_ignore("__nonexistent_47__.env")
}

test "load_dotenv nonexistent file returns Err" {
    match env.load_dotenv("__nonexistent_47__.env") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "ENV_DOTENV_NOT_FOUND"))
    }
}

test "require error message contains key name" {
    match env.require("__FAV_ENV_TEST_47_KEY_NAME__") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "__FAV_ENV_TEST_47_KEY_NAME__"))
    }
}

test "require_int error message contains key name" {
    match env.require_int("__FAV_ENV_TEST_47_INT_KEY__") {
        Ok(_)  => assert(false)
        Err(e) => assert(String.contains(e, "__FAV_ENV_TEST_47_INT_KEY__"))
    }
}

test "get with empty default" {
    assert(env.get("__FAV_ENV_TEST_47_MISSING_I__", "") == "")
}

test "multiple env calls in sequence" {
    assert(env.get("__FAV_ENV_TEST_47_MISSING_J__", "seq_default") == "seq_default")
}
