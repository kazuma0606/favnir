import "csv"

type User = {
    id: Int
    name: String
    age: Int
}

public fn main(ctx: AppCtx) -> Unit {
    bind text <- File.read("users.csv")
    bind result <- csv.parse<User>(text)
    match result {
        Ok(users) => {
            ctx.io.println($"Loaded {List.length(users)} users");
            bind out <- csv.write<User>(users)
            ctx.io.println(out);
        }
        Err(err) => {
            ctx.io.println($"CSV error: {Debug.show(err)}")
        }
    }
}
