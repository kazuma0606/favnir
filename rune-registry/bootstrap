#!/bin/bash
# Lambda Custom Runtime bootstrap for Favnir rune-registry
# Polls the Lambda Runtime API, runs `fav run` per invocation, posts the response.
set -euo pipefail

BASE="http://${AWS_LAMBDA_RUNTIME_API}/2018-06-01/runtime"

while true; do
  # ── Get next invocation ──────────────────────────────────────────────────
  HDR=$(mktemp)
  EVENT=$(curl -sS -D "$HDR" "${BASE}/invocation/next")
  REQUEST_ID=$(grep -i '^lambda-runtime-aws-request-id:' "$HDR" \
    | tr -d '\r' | sed 's/[^:]*: //')
  rm -f "$HDR"

  # ── Extract request fields from Lambda Function URL event ────────────────
  # API Gateway omits or nulls optional objects such as headers/queryStringParameters.
  # Guard every lookup so one missing field does not fail the whole Lambda invocation.
  METHOD=$(printf '%s' "$EVENT" \
    | jq -r '((.requestContext // {}) | (.http // {}) | .method // "GET")' 2>/dev/null \
    || printf 'GET')
  REQ_PATH=$(printf '%s' "$EVENT" \
    | jq -r '((.requestContext // {}) | (.http // {}) | .path // "/")' 2>/dev/null \
    || printf '/')
  BODY=$(printf '%s' "$EVENT" \
    | jq -r '(.body // "")' 2>/dev/null \
    || printf '')
  AUTH=$(printf '%s' "$EVENT" \
    | jq -r '((.headers // {}) | .authorization // .Authorization // "")' 2>/dev/null \
    || printf '')
  QUERY_VERSION=$(printf '%s' "$EVENT" \
    | jq -r '((.queryStringParameters // {}) | .version // "")' 2>/dev/null \
    || printf '')
  FAV_TOKEN=$(printf '%s' "$EVENT" \
    | jq -r '((.headers // {}) | .["x-fav-token"] // .["X-Fav-Token"] // "")' 2>/dev/null \
    || printf '')

  # ── Run Favnir handler ───────────────────────────────────────────────────
  # stdout → Favnir's IO.println JSON output; stderr → CloudWatch Logs
  # --legacy: use Rust pipeline (parser/checker/codegen) for stability
  OUTPUT=$(
    FAV_METHOD="$METHOD" \
    FAV_PATH="$REQ_PATH" \
    FAV_BODY="$BODY" \
    FAV_AUTH="$AUTH" \
    FAV_QUERY_VERSION="$QUERY_VERSION" \
    FAV_FAV_TOKEN="$FAV_TOKEN" \
    /usr/local/bin/fav run --legacy /app/src/main.fav 2>/dev/stderr
  ) || OUTPUT=''

  # ── Convert Favnir map JSON → Lambda Function URL response ───────────────
  # Favnir outputs: {"status":"200","body":"...","content_type":"...","is_base64":"true"|"false"}
  # Lambda expects: {"statusCode":200,"headers":{...},"body":"...","isBase64Encoded":true}
  IS_B64=$(printf '%s' "$OUTPUT" | jq -r '.is_base64 // "false"' 2>/dev/null)
  if [ "$IS_B64" = "true" ]; then
    RESP=$(printf '%s' "$OUTPUT" | jq -c \
      '{statusCode:(.status|tonumber),
        headers:{"Content-Type":.content_type},
        body:.body,
        isBase64Encoded:true}' 2>/dev/null) \
      || RESP='{"statusCode":500,"headers":{"Content-Type":"text/plain"},"body":"internal error"}'
  else
    RESP=$(printf '%s' "$OUTPUT" | jq -c \
      '{statusCode:(.status|tonumber),
        headers:{"Content-Type":.content_type},
        body:.body}' 2>/dev/null) \
      || RESP='{"statusCode":500,"headers":{"Content-Type":"text/plain"},"body":"internal error"}'
  fi

  # ── Post response ────────────────────────────────────────────────────────
  curl -sS -X POST \
    -H 'Content-Type: application/json' \
    -d "$RESP" \
    "${BASE}/invocation/${REQUEST_ID}/response" > /dev/null
done
