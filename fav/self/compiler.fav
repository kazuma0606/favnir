type Token =
    | TkInt(Int)
    | TkFloat(Float)
    | TkStr(String)
    | TkIdent(String)
    | TkTrue
    | TkFalse
    | TkFn
    | TkType
    | TkIf
    | TkElse
    | TkMatch
    | TkWhere
    | TkWith
    | TkBind
    | TkImport
    | TkPublic
    | TkReturn
    | TkFor
    | TkIn
    | TkTest
    | TkBench
    | TkCollect
    | TkYield
    | TkPlus
    | TkMinus
    | TkStar
    | TkSlash
    | TkPercent
    | TkEqEq
    | TkBangEq
    | TkLtEq
    | TkGtEq
    | TkAmpAmp
    | TkPipePipe
    | TkArrow
    | TkBackArrow
    | TkFatArrow
    | TkPipeGt
    | TkEq
    | TkBang
    | TkLt
    | TkGt
    | TkPipe
    | TkDot
    | TkComma
    | TkColon
    | TkSemicolon
    | TkLParen
    | TkRParen
    | TkLBrace
    | TkRBrace
    | TkLBracket
    | TkRBracket
    | TkPar
    | TkStage
    | TkSeq
    | TkAbstract
    | TkInterface
    | TkImpl
    | TkQuestion
    | TkQuestionQuestion
    | TkDocComment(String)
    | TkEof

type ScanResult = {
    tok: Token
    rest: List<String>
}

fn is_digit(c: String) -> Bool {
    String.contains("0123456789", c)
}

fn is_alpha(c: String) -> Bool {
    String.contains("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_", c)
}

fn is_alnum(c: String) -> Bool {
    is_alpha(c) || is_digit(c)
}

fn is_whitespace(c: String) -> Bool {
    (((c == " ") || (c == "\t")) || (c == "\r")) || (c == "\n")
}

fn keyword_token(s: String) -> Option<Token> {
    if s == "fn" {
        Option.some(TkFn)
    } else {
        if s == "type" {
            Option.some(TkType)
        } else {
            if s == "if" {
                Option.some(TkIf)
            } else {
                if s == "else" {
                    Option.some(TkElse)
                } else {
                    if s == "match" {
                        Option.some(TkMatch)
                    } else {
                        if s == "where" {
                            Option.some(TkWhere)
                        } else {
                            if s == "with" {
                                Option.some(TkWith)
                            } else {
                                if s == "bind" {
                                    Option.some(TkBind)
                                } else {
                                    if s == "import" {
                                        Option.some(TkImport)
                                    } else {
                                        if s == "public" {
                                            Option.some(TkPublic)
                                        } else {
                                            if s == "return" {
                                                Option.some(TkReturn)
                                            } else {
                                                if s == "for" {
                                                    Option.some(TkFor)
                                                } else {
                                                    if s == "in" {
                                                        Option.some(TkIn)
                                                    } else {
                                                        if s == "test" {
                                                            Option.some(TkTest)
                                                        } else {
                                                            if s == "bench" {
                                                                Option.some(TkBench)
                                                            } else {
                                                                if s == "collect" {
                                                                    Option.some(TkCollect)
                                                                } else {
                                                                    if s == "yield" {
                                                                        Option.some(TkYield)
                                                                    } else {
                                                                        if s == "true" {
                                                                            Option.some(TkTrue)
                                                                        } else {
                                                                            if s == "false" {
                                                                                Option.some(TkFalse)
                                                                            } else {
                                                                                if s == "par" {
                                                                                    Option.some(TkPar)
                                                                                } else {
                                                                                    if s == "stage" {
                                                                                        Option.some(TkStage)
                                                                                    } else {
                                                                                        if s == "seq" {
                                                                                            Option.some(TkSeq)
                                                                                        } else {
                                                                                            if s == "abstract" {
                                                                                                Option.some(TkAbstract)
                                                                                            } else {
                                                                                                if s == "interface" {
                                                                                                    Option.some(TkInterface)
                                                                                                } else {
                                                                                                    if s == "impl" {
                                                                                                        Option.some(TkImpl)
                                                                                                    } else {
                                                                                                        Option.none()
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn scan_string_chars(chars: List<String>, acc: List<String>) -> Result<ScanResult, String> {
    match List.first(chars) {
        None => Result.err("unterminated string literal")
        Some(c) => {
            bind tail <- List.drop(chars, 1);
            if c == "\"" {
                bind s <- String.from_chars(List.reverse(acc));
                Result.ok(ScanResult { tok: TkStr(s)  rest: tail })
            } else {
                if c == "\\" {
                    match List.first(tail) {
                        None => Result.err("unterminated escape sequence")
                        Some(esc) => {
                            bind after_esc <- List.drop(tail, 1);
                            bind ch <- if esc == "n" {
                                "\n"
                            } else {
                                if esc == "t" {
                                    "\t"
                                } else {
                                    if esc == "r" {
                                        "\r"
                                    } else {
                                        if esc == "\"" {
                                            "\""
                                        } else {
                                            if esc == "\\" {
                                                "\\"
                                            } else {
                                                esc
                                            }
                                        }
                                    }
                                }
                            };
                            scan_string_chars(after_esc, List.concat(List.singleton(ch), acc))
                        }
                    }
                } else {
                    scan_string_chars(tail, List.concat(List.singleton(c), acc))
                }
            }
        }
    }
}

fn build_int_token(digits: List<String>, rest: List<String>) -> Result<ScanResult, String> {
    bind s <- String.from_chars(digits);
    match String.to_int(s) {
        None => Result.err(String.concat("invalid integer: ", s))
        Some(n) => Result.ok(ScanResult { tok: TkInt(n)  rest: rest })
    }
}

fn scan_number(chars: List<String>) -> Result<ScanResult, String> {
    bind int_chars <- List.take_while(chars, |c| is_digit(c));
    bind after_int <- List.drop_while(chars, |c| is_digit(c));
    match List.first(after_int) {
        Some(".") => {
            bind after_dot <- List.drop(after_int, 1);
            match List.first(after_dot) {
                Some(d) => {
                    if is_digit(d) {
                        bind frac_chars <- List.take_while(after_dot, |c| is_digit(c));
                        bind after_frac <- List.drop_while(after_dot, |c| is_digit(c));
                        bind s <- String.from_chars(List.concat(int_chars, List.concat(List.singleton("."), frac_chars)));
                        match String.to_float(s) {
                            None => Result.err(String.concat("invalid float: ", s))
                            Some(f) => Result.ok(ScanResult { tok: TkFloat(f)  rest: after_frac })
                        }
                    } else {
                        build_int_token(int_chars, after_int)
                    }
                }
                _ => build_int_token(int_chars, after_int)
            }
        }
        _ => build_int_token(int_chars, after_int)
    }
}

fn skip_line_comment(chars: List<String>) -> List<String> {
    List.drop_while(chars, |c| c != "\n")
}

fn next_char_is(chars: List<String>, expected: String) -> Bool {
    match List.first(chars) {
        Some(c) => c == expected
        None => false
    }
}

fn single_char_token(c: String) -> Option<Token> {
    if c == "+" {
        Option.some(TkPlus)
    } else {
        if c == "-" {
            Option.some(TkMinus)
        } else {
            if c == "*" {
                Option.some(TkStar)
            } else {
                if c == "/" {
                    Option.some(TkSlash)
                } else {
                    if c == "%" {
                        Option.some(TkPercent)
                    } else {
                        if c == "=" {
                            Option.some(TkEq)
                        } else {
                            if c == "<" {
                                Option.some(TkLt)
                            } else {
                                if c == ">" {
                                    Option.some(TkGt)
                                } else {
                                    if c == "!" {
                                        Option.some(TkBang)
                                    } else {
                                        if c == "|" {
                                            Option.some(TkPipe)
                                        } else {
                                            if c == "." {
                                                Option.some(TkDot)
                                            } else {
                                                if c == "," {
                                                    Option.some(TkComma)
                                                } else {
                                                    if c == ":" {
                                                        Option.some(TkColon)
                                                    } else {
                                                        if c == ";" {
                                                            Option.some(TkSemicolon)
                                                        } else {
                                                            if c == "(" {
                                                                Option.some(TkLParen)
                                                            } else {
                                                                if c == ")" {
                                                                    Option.some(TkRParen)
                                                                } else {
                                                                    if c == "{" {
                                                                        Option.some(TkLBrace)
                                                                    } else {
                                                                        if c == "}" {
                                                                            Option.some(TkRBrace)
                                                                        } else {
                                                                            if c == "[" {
                                                                                Option.some(TkLBracket)
                                                                            } else {
                                                                                if c == "]" {
                                                                                    Option.some(TkRBracket)
                                                                                } else {
                                                                                    Option.none()
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn scan_op(c: String, tail: List<String>) -> Result<ScanResult, String> {
    if (c == "-") && next_char_is(tail, ">") {
        Result.ok(ScanResult { tok: TkArrow  rest: List.drop(tail, 1) })
    } else {
        if (c == "<") && next_char_is(tail, "-") {
            Result.ok(ScanResult { tok: TkBackArrow  rest: List.drop(tail, 1) })
        } else {
            if (c == "=") && next_char_is(tail, "=") {
                Result.ok(ScanResult { tok: TkEqEq  rest: List.drop(tail, 1) })
            } else {
                if (c == "=") && next_char_is(tail, ">") {
                    Result.ok(ScanResult { tok: TkFatArrow  rest: List.drop(tail, 1) })
                } else {
                    if (c == "!") && next_char_is(tail, "=") {
                        Result.ok(ScanResult { tok: TkBangEq  rest: List.drop(tail, 1) })
                    } else {
                        if (c == "<") && next_char_is(tail, "=") {
                            Result.ok(ScanResult { tok: TkLtEq  rest: List.drop(tail, 1) })
                        } else {
                            if (c == ">") && next_char_is(tail, "=") {
                                Result.ok(ScanResult { tok: TkGtEq  rest: List.drop(tail, 1) })
                            } else {
                                if (c == "&") && next_char_is(tail, "&") {
                                    Result.ok(ScanResult { tok: TkAmpAmp  rest: List.drop(tail, 1) })
                                } else {
                                    if (c == "|") && next_char_is(tail, "|") {
                                        Result.ok(ScanResult { tok: TkPipePipe  rest: List.drop(tail, 1) })
                                    } else {
                                        if (c == "|") && next_char_is(tail, ">") {
                                            Result.ok(ScanResult { tok: TkPipeGt  rest: List.drop(tail, 1) })
                                        } else {
                                            if (c == "?") && next_char_is(tail, "?") {
                                                Result.ok(ScanResult { tok: TkQuestionQuestion  rest: List.drop(tail, 1) })
                                            } else {
                                                if c == "?" {
                                                    Result.ok(ScanResult { tok: TkQuestion  rest: tail })
                                                } else {
                                                    match single_char_token(c) {
                                                        Some(t) => Result.ok(ScanResult { tok: t  rest: tail })
                                                        None => Result.err(String.concat("unexpected character: ", c))
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn scan_collect(chars: List<String>) -> Bool {
    bind trimmed <- List.drop_while(chars, |c| is_whitespace(c));
    match List.first(trimmed) {
        None => {
            yield Result.ok(TkEof);
            true
        }
        Some(c) => {
            bind tail <- List.drop(trimmed, 1);
            if (c == "/") && next_char_is(tail, "/") {
                bind after_two <- List.drop(tail, 1);
                if next_char_is(after_two, "/") {
                    bind doc_rest <- List.drop(after_two, 1);
                    bind doc_chars <- List.drop_while(doc_rest, |ch| (ch == " ") || (ch == "\t"));
                    bind text_chars <- List.take_while(doc_chars, |ch| ch != "\n");
                    bind text <- String.from_chars(text_chars);
                    yield Result.ok(TkDocComment(text));
                    scan_collect(skip_line_comment(after_two))
                } else {
                    scan_collect(skip_line_comment(after_two))
                }
            } else {
                if c == "\"" {
                    bind str_acc <- List.drop_while(List.singleton(""), |x| true);
                    match scan_string_chars(tail, str_acc) {
                        Err(e) => {
                            yield Result.err(e);
                            true
                        }
                        Ok(r) => {
                            yield Result.ok(r.tok);
                            scan_collect(r.rest)
                        }
                    }
                } else {
                    if is_digit(c) {
                        match scan_number(trimmed) {
                            Err(e) => {
                                yield Result.err(e);
                                true
                            }
                            Ok(r) => {
                                yield Result.ok(r.tok);
                                scan_collect(r.rest)
                            }
                        }
                    } else {
                        if is_alpha(c) {
                            bind word_chars <- List.take_while(trimmed, |ch| is_alnum(ch));
                            bind rest <- List.drop_while(trimmed, |ch| is_alnum(ch));
                            bind word <- String.from_chars(word_chars);
                            bind tok <- match keyword_token(word) {
                                Some(t) => t
                                None => TkIdent(word)
                            };
                            yield Result.ok(tok);
                            scan_collect(rest)
                        } else {
                            match scan_op(c, tail) {
                                Err(e) => {
                                    yield Result.err(e);
                                    true
                                }
                                Ok(r) => {
                                    yield Result.ok(r.tok);
                                    scan_collect(r.rest)
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn scan_entries(chars: List<String>) -> List<Result<Token, String>> {
    collect {
        scan_collect(chars)
    }
}

fn first_scan_error(entries: List<Result<Token, String>>) -> Option<String> {
    match List.first(entries) {
        None => Option.none()
        Some(entry) => {
            match entry {
                Err(e) => Option.some(e)
                Ok(_) => first_scan_error(List.drop(entries, 1))
            }
        }
    }
}

fn unwrap_scan_entry(entry: Result<Token, String>) -> Token {
    match entry {
        Ok(tok) => tok
        Err(_) => TkEof
    }
}

fn lex(src: String) -> Result<List<Token>, String> {
    bind chars <- String.chars(src);
    bind entries <- scan_entries(chars);
    match first_scan_error(entries) {
        Some(e) => Result.err(e)
        None => Result.ok(List.map(entries, |entry| unwrap_scan_entry(entry)))
    }
}

type Lit =
    | LInt(Int)
    | LFloat(Float)
    | LStr(String)
    | LBool(Bool)
    | LUnit

type Op =
    | OpAdd
    | OpSub
    | OpMul
    | OpDiv
    | OpMod
    | OpEq
    | OpNeq
    | OpLt
    | OpGt
    | OpLtEq
    | OpGtEq
    | OpAnd
    | OpOr
    | OpNullCoalesce

type Pat =
    | PWild
    | PVar(String)
    | PInt(Int)
    | PFloat(Float)
    | PStr(String)
    | PBool(Bool)
    | PUnit
    | PVariant(String)
    | PVariantP(String, Pat)

type Expr =
    | ELit(Lit)
    | EVar(String)
    | EBinOp(Op, Expr, Expr)
    | ECall(String, String, Expr)
    | EIf(Expr, Expr, Expr)
    | EAccess(Expr, String)
    | ELambda(String, Expr)
    | EMatch(Expr, Expr)
    | EBlock(Expr, Expr)
    | ERecordLit(String, Expr)
    | EArgList(Expr, Expr)
    | EArgNil
    | EArm(Pat, Expr, Expr, Expr)
    | EArmNil
    | EBind(String, Expr, Expr)
    | ECollect(Expr)
    | EYield(Expr)
    | EField(String, Expr, Expr)
    | EFieldNil
    | EQuestion(Expr)

type TypeExpr =
    | TeSimple(String)
    | TeList(TypeExpr)
    | TeOption(TypeExpr)
    | TeResult(TypeExpr, TypeExpr)
    | TeMap(TypeExpr, TypeExpr)
    | TeFn(TypeExpr, TypeExpr)

type Param = {
    name: String
    ty: TypeExpr
}

type FnDef = {
    is_public: Bool
    name: String
    params: List<Param>
    ret: TypeExpr
    body: Expr
    doc: String
}

type VariantDef = {
    name: String
    payload: Option<TypeExpr>
}

type TypeDef = {
    name: String
    is_record: Bool
    variants: List<VariantDef>
    fields: List<Param>
    doc: String
}

type TestDef = {
    name: String
    body: Expr
}

type StageDef = {
    is_public: Bool
    is_abstract: Bool
    name: String
    param_ty: TypeExpr
    ret_ty: TypeExpr
    effects: List<String>
    body: Option<Expr>
    doc: String
}

type SeqStep =
    | SStage(String)
    | SPar(List<String>)

type SeqDef = {
    is_public: Bool
    is_abstract: Bool
    name: String
    stages: List<SeqStep>
    doc: String
}

type WrapperDef = {
    name: String
    inner: String
    where_pred: Expr
    with_impls: List<String>
    doc: String
}

type InterfaceMethodDecl = {
    name: String
    ty: String
}

type InterfaceDef = {
    name: String
    methods: List<InterfaceMethodDecl>
}

type ImplDeclDef = {
    interface_names: List<String>
    type_name: String
    methods: List<FnDef>
}

type Item =
    | IFn(FnDef)
    | IType(TypeDef)
    | ITest(TestDef)
    | IStage(StageDef)
    | ISeq(SeqDef)
    | IWrapper(WrapperDef)
    | IInterface(InterfaceDef)
    | IImpl(ImplDeclDef)

type Program = {
    items: List<Item>
}

type ExprParse = {
    expr: Expr
    rest: List<Token>
}

type PatParse = {
    pat: Pat
    rest: List<Token>
}

type TypeExprParse = {
    ty: TypeExpr
    rest: List<Token>
}

type ParamParse = {
    param: Param
    rest: List<Token>
}

type ParamsParse = {
    params: List<Param>
    rest: List<Token>
}

type FnDefParse = {
    fn_def: FnDef
    rest: List<Token>
}

type VariantDefParse = {
    variant: VariantDef
    rest: List<Token>
}

type VariantsParse = {
    variants: List<VariantDef>
    rest: List<Token>
}

type TypeDefParse = {
    type_def: TypeDef
    rest: List<Token>
}

type ItemParse = {
    item: Item
    rest: List<Token>
}

type ItemsParse = {
    items: List<Item>
    rest: List<Token>
}

type StageDefParse = {
    stage_def: StageDef
    rest: List<Token>
}

type SeqDefParse = {
    seq_def: SeqDef
    rest: List<Token>
}

type EffectsParse = {
    effects: List<String>
    rest: List<Token>
}

type PipelineStepsParse = {
    stages: List<SeqStep>
    rest: List<Token>
}

type ParNamesParse = {
    names: List<String>
    rest: List<Token>
}

type SeqStepParse = {
    step: SeqStep
    rest: List<Token>
}

type InterfaceMethodDeclParse = {
    method: InterfaceMethodDecl
    rest: List<Token>
}

type InterfaceMethodDeclsParse = {
    methods: List<InterfaceMethodDecl>
    rest: List<Token>
}

type ImplMethodsParse = {
    methods: List<FnDef>
    rest: List<Token>
}

fn peek(toks: List<Token>) -> Option<Token> {
    List.first(toks)
}

fn advance(toks: List<Token>) -> List<Token> {
    List.drop(toks, 1)
}

fn token_eq(a: Token, b: Token) -> Bool {
    match a {
        TkInt(n) => {
            match b {
                TkInt(m) => n == m
                _ => false
            }
        }
        TkFloat(f) => {
            match b {
                TkFloat(g) => f == g
                _ => false
            }
        }
        TkStr(s) => {
            match b {
                TkStr(t) => s == t
                _ => false
            }
        }
        TkIdent(s) => {
            match b {
                TkIdent(t) => s == t
                _ => false
            }
        }
        TkTrue => {
            match b {
                TkTrue => true
                _ => false
            }
        }
        TkFalse => {
            match b {
                TkFalse => true
                _ => false
            }
        }
        TkFn => {
            match b {
                TkFn => true
                _ => false
            }
        }
        TkType => {
            match b {
                TkType => true
                _ => false
            }
        }
        TkIf => {
            match b {
                TkIf => true
                _ => false
            }
        }
        TkElse => {
            match b {
                TkElse => true
                _ => false
            }
        }
        TkMatch => {
            match b {
                TkMatch => true
                _ => false
            }
        }
        TkBind => {
            match b {
                TkBind => true
                _ => false
            }
        }
        TkImport => {
            match b {
                TkImport => true
                _ => false
            }
        }
        TkPublic => {
            match b {
                TkPublic => true
                _ => false
            }
        }
        TkReturn => {
            match b {
                TkReturn => true
                _ => false
            }
        }
        TkFor => {
            match b {
                TkFor => true
                _ => false
            }
        }
        TkIn => {
            match b {
                TkIn => true
                _ => false
            }
        }
        TkTest => {
            match b {
                TkTest => true
                _ => false
            }
        }
        TkBench => {
            match b {
                TkBench => true
                _ => false
            }
        }
        TkCollect => {
            match b {
                TkCollect => true
                _ => false
            }
        }
        TkYield => {
            match b {
                TkYield => true
                _ => false
            }
        }
        TkPlus => {
            match b {
                TkPlus => true
                _ => false
            }
        }
        TkMinus => {
            match b {
                TkMinus => true
                _ => false
            }
        }
        TkStar => {
            match b {
                TkStar => true
                _ => false
            }
        }
        TkSlash => {
            match b {
                TkSlash => true
                _ => false
            }
        }
        TkPercent => {
            match b {
                TkPercent => true
                _ => false
            }
        }
        TkEqEq => {
            match b {
                TkEqEq => true
                _ => false
            }
        }
        TkBangEq => {
            match b {
                TkBangEq => true
                _ => false
            }
        }
        TkLtEq => {
            match b {
                TkLtEq => true
                _ => false
            }
        }
        TkGtEq => {
            match b {
                TkGtEq => true
                _ => false
            }
        }
        TkAmpAmp => {
            match b {
                TkAmpAmp => true
                _ => false
            }
        }
        TkPipePipe => {
            match b {
                TkPipePipe => true
                _ => false
            }
        }
        TkArrow => {
            match b {
                TkArrow => true
                _ => false
            }
        }
        TkBackArrow => {
            match b {
                TkBackArrow => true
                _ => false
            }
        }
        TkFatArrow => {
            match b {
                TkFatArrow => true
                _ => false
            }
        }
        TkWhere => {
            match b {
                TkWhere => true
                _ => false
            }
        }
        TkWith => {
            match b {
                TkWith => true
                _ => false
            }
        }
        TkPipeGt => {
            match b {
                TkPipeGt => true
                _ => false
            }
        }
        TkEq => {
            match b {
                TkEq => true
                _ => false
            }
        }
        TkBang => {
            match b {
                TkBang => true
                _ => false
            }
        }
        TkLt => {
            match b {
                TkLt => true
                _ => false
            }
        }
        TkGt => {
            match b {
                TkGt => true
                _ => false
            }
        }
        TkPipe => {
            match b {
                TkPipe => true
                _ => false
            }
        }
        TkDot => {
            match b {
                TkDot => true
                _ => false
            }
        }
        TkComma => {
            match b {
                TkComma => true
                _ => false
            }
        }
        TkColon => {
            match b {
                TkColon => true
                _ => false
            }
        }
        TkSemicolon => {
            match b {
                TkSemicolon => true
                _ => false
            }
        }
        TkLParen => {
            match b {
                TkLParen => true
                _ => false
            }
        }
        TkRParen => {
            match b {
                TkRParen => true
                _ => false
            }
        }
        TkLBrace => {
            match b {
                TkLBrace => true
                _ => false
            }
        }
        TkRBrace => {
            match b {
                TkRBrace => true
                _ => false
            }
        }
        TkLBracket => {
            match b {
                TkLBracket => true
                _ => false
            }
        }
        TkRBracket => {
            match b {
                TkRBracket => true
                _ => false
            }
        }
        TkPar => {
            match b {
                TkPar => true
                _ => false
            }
        }
        TkStage => {
            match b {
                TkStage => true
                _ => false
            }
        }
        TkSeq => {
            match b {
                TkSeq => true
                _ => false
            }
        }
        TkAbstract => {
            match b {
                TkAbstract => true
                _ => false
            }
        }
        TkInterface => {
            match b {
                TkInterface => true
                _ => false
            }
        }
        TkImpl => {
            match b {
                TkImpl => true
                _ => false
            }
        }
        TkDocComment(s) => {
            match b {
                TkDocComment(t) => s == t
                _ => false
            }
        }
        TkEof => {
            match b {
                TkEof => true
                _ => false
            }
        }
        TkQuestion => {
            match b {
                TkQuestion => true
                _ => false
            }
        }
        TkQuestionQuestion => {
            match b {
                TkQuestionQuestion => true
                _ => false
            }
        }
    }
}

fn token_to_string(t: Token) -> String {
    match t {
        TkInt(n) => String.concat("int:", Int.to_string(n))
        TkFloat(f) => "float"
        TkStr(s) => String.concat("str:", s)
        TkIdent(s) => String.concat("ident:", s)
        TkTrue => "true"
        TkFalse => "false"
        TkFn => "fn"
        TkType => "type"
        TkIf => "if"
        TkElse => "else"
        TkMatch => "match"
        TkWhere => "where"
        TkWith => "with"
        TkBind => "bind"
        TkImport => "import"
        TkPublic => "public"
        TkReturn => "return"
        TkFor => "for"
        TkIn => "in"
        TkTest => "test"
        TkBench => "bench"
        TkPlus => "+"
        TkMinus => "-"
        TkStar => "*"
        TkSlash => "/"
        TkPercent => "%"
        TkEqEq => "=="
        TkBangEq => "!="
        TkLtEq => "<="
        TkGtEq => ">="
        TkAmpAmp => "&&"
        TkPipePipe => "||"
        TkArrow => "->"
        TkBackArrow => "<-"
        TkFatArrow => "=>"
        TkPipeGt => "|>"
        TkEq => "="
        TkBang => "!"
        TkLt => "<"
        TkGt => ">"
        TkPipe => "|"
        TkDot => "."
        TkComma => ","
        TkColon => ":"
        TkSemicolon => ";"
        TkLParen => "("
        TkRParen => ")"
        TkLBrace => "{"
        TkRBrace => "}"
        TkLBracket => "["
        TkRBracket => "]"
        TkPar => "par"
        TkStage => "stage"
        TkSeq => "seq"
        TkAbstract => "abstract"
        TkInterface => "interface"
        TkImpl => "impl"
        TkDocComment(s) => String.concat("///", s)
        TkEof => "EOF"
        TkCollect => "collect"
        TkYield => "yield"
        TkQuestion => "?"
        TkQuestionQuestion => "??"
    }
}

fn expect_tok(toks: List<Token>, expected: Token) -> Result<List<Token>, String> {
    match peek(toks) {
        None => Result.err("unexpected end of input")
        Some(t) => {
            if token_eq(t, expected) {
                Result.ok(advance(toks))
            } else {
                Result.err(String.concat("unexpected token: got ", String.concat(token_to_string(t), String.concat(", expected ", token_to_string(expected)))))
            }
        }
    }
}

fn skip_extra_pat_args(toks: List<Token>) -> Result<List<Token>, String> {
    match peek(toks) {
        Some(TkComma) => {
            bind rest1 <- advance(toks);
            match parse_pat(rest1) {
                Ok(pp) => skip_extra_pat_args(pp.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(toks)
    }
}

fn parse_pat(toks: List<Token>) -> Result<PatParse, String> {
    match peek(toks) {
        None => Result.err("expected pattern")
        Some(TkIdent(name)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkLParen) => {
                    bind rest2 <- advance(rest1);
                    match parse_pat(rest2) {
                        Err(e) => Result.err(e)
                        Ok(inner) => {
                            match skip_extra_pat_args(inner.rest) {
                                Err(e) => Result.err(e)
                                Ok(rest_mid) => {
                                    match expect_tok(rest_mid, TkRParen) {
                                        Err(e) => Result.err(e)
                                        Ok(rest3) => Result.ok(PatParse { pat: PVariantP(name, inner.pat)  rest: rest3 })
                                    }
                                }
                            }
                        }
                    }
                }
                _ => {
                    if String.contains("ABCDEFGHIJKLMNOPQRSTUVWXYZ", String.slice(name, 0, 1)) {
                        Result.ok(PatParse { pat: PVariant(name)  rest: rest1 })
                    } else {
                        Result.ok(PatParse { pat: PVar(name)  rest: rest1 })
                    }
                }
            }
        }
        Some(TkInt(n)) => Result.ok(PatParse { pat: PInt(n)  rest: advance(toks) })
        Some(TkFloat(f)) => Result.ok(PatParse { pat: PFloat(f)  rest: advance(toks) })
        Some(TkStr(s)) => Result.ok(PatParse { pat: PStr(s)  rest: advance(toks) })
        Some(TkTrue) => Result.ok(PatParse { pat: PBool(true)  rest: advance(toks) })
        Some(TkFalse) => Result.ok(PatParse { pat: PBool(false)  rest: advance(toks) })
        Some(TkLParen) => {
            match expect_tok(toks, TkLParen) {
                Err(e) => Result.err(e)
                Ok(rest1) => {
                    match expect_tok(rest1, TkRParen) {
                        Err(e) => Result.err(e)
                        Ok(rest2) => Result.ok(PatParse { pat: PUnit  rest: rest2 })
                    }
                }
            }
        }
        _ => Result.ok(PatParse { pat: PWild  rest: advance(toks) })
    }
}

fn skip_extra_type_args(toks: List<Token>) -> Result<List<Token>, String> {
    match peek(toks) {
        Some(TkComma) => {
            bind rest1 <- advance(toks);
            match parse_type_expr(rest1) {
                Ok(tp) => skip_extra_type_args(tp.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(toks)
    }
}

fn parse_type_expr_postfix(base: TypeExprParse) -> Result<TypeExprParse, String> {
    match peek(base.rest) {
        Some(TkQuestion) => {
            match advance(base.rest) {
                rest_q => Result.ok(TypeExprParse { ty: TeOption(base.ty)  rest: rest_q })
            }
        }
        _ => Result.ok(base)
    }
}

fn parse_type_expr(toks: List<Token>) -> Result<TypeExprParse, String> {
    match peek(toks) {
        None => Result.err("expected type")
        Some(TkIdent(name)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkLt) => {
                    bind rest2 <- advance(rest1);
                    match parse_type_expr(rest2) {
                        Err(e) => Result.err(e)
                        Ok(inner) => {
                            match skip_extra_type_args(inner.rest) {
                                Err(e) => Result.err(e)
                                Ok(rest_after) => {
                                    match expect_tok(rest_after, TkGt) {
                                        Err(e) => Result.err(e)
                                        Ok(rest3) => {
                                            bind base_ty <- if name == "List" {
                                                TypeExprParse { ty: TeList(inner.ty)  rest: rest3 }
                                            } else {
                                                if name == "Option" {
                                                    TypeExprParse { ty: TeOption(inner.ty)  rest: rest3 }
                                                } else {
                                                    TypeExprParse { ty: TeSimple(name)  rest: rest3 }
                                                }
                                            };
                                            parse_type_expr_postfix(base_ty)
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                _ => parse_type_expr_postfix(TypeExprParse { ty: TeSimple(name)  rest: rest1 })
            }
        }
        _ => Result.err("expected type name")
    }
}

fn parse_arm_guard(toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkWhere) => {
            bind rest1 <- advance(toks);
            match parse_expr(rest1) {
                Err(e) => Result.err(e)
                Ok(guard_p) => Result.ok(ExprParse { expr: guard_p.expr  rest: guard_p.rest })
            }
        }
        _ => Result.ok(ExprParse { expr: ELit(LBool(true))  rest: toks })
    }
}

fn parse_arms(toks: List<Token>, acc: Expr) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkRBrace) => Result.ok(ExprParse { expr: reverse_match_arms(acc)  rest: toks })
        Some(TkEof) => Result.err("unterminated match")
        _ => {
            match parse_pat(toks) {
                Err(e) => Result.err(e)
                Ok(pat_p) => {
                    match parse_arm_guard(pat_p.rest) {
                        Err(e) => Result.err(e)
                        Ok(guard_p) => {
                            match expect_tok(guard_p.rest, TkFatArrow) {
                                Err(e) => Result.err(e)
                                Ok(rest1) => {
                                    match parse_expr(rest1) {
                                        Err(e) => Result.err(e)
                                        Ok(body_p) => {
                                            parse_arms(match peek(body_p.rest) {
                                                Some(TkComma) => advance(body_p.rest)
                                                _ => body_p.rest
                                            }, EArm(pat_p.pat, guard_p.expr, body_p.expr, acc))
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

fn parse_args(toks: List<Token>, acc: Expr) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkRParen) => Result.ok(ExprParse { expr: acc  rest: toks })
        Some(TkEof) => Result.err("unterminated argument list")
        _ => {
            match parse_expr(toks) {
                Err(e) => Result.err(e)
                Ok(arg_p) => {
                    parse_args(match peek(arg_p.rest) {
                        Some(TkComma) => advance(arg_p.rest)
                        _ => arg_p.rest
                    }, EArgList(arg_p.expr, acc))
                }
            }
        }
    }
}

fn parse_fields(toks: List<Token>, acc: Expr) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkRBrace) => Result.ok(ExprParse { expr: acc  rest: toks })
        Some(TkEof) => Result.err("unterminated record")
        _ => {
            match peek(toks) {
                Some(TkIdent(fname)) => {
                    bind rest1 <- advance(toks);
                    match expect_tok(rest1, TkColon) {
                        Err(e) => Result.err(e)
                        Ok(rest2) => {
                            match parse_expr(rest2) {
                                Err(e) => Result.err(e)
                                Ok(val_p) => {
                                    parse_fields(match peek(val_p.rest) {
                                        Some(TkComma) => advance(val_p.rest)
                                        _ => val_p.rest
                                    }, EField(fname, val_p.expr, acc))
                                }
                            }
                        }
                    }
                }
                _ => Result.err("expected field name")
            }
        }
    }
}

fn parse_block_inner(toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkRBrace) => Result.ok(ExprParse { expr: ELit(LUnit)  rest: toks })
        Some(TkBind) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(vname)) => {
                    bind rest2 <- advance(rest1);
                    match expect_tok(rest2, TkBackArrow) {
                        Err(e) => Result.err(e)
                        Ok(rest3) => {
                            match parse_expr(rest3) {
                                Err(e) => Result.err(e)
                                Ok(val_p) => {
                                    match parse_block_inner(match peek(val_p.rest) {
                                        Some(TkSemicolon) => advance(val_p.rest)
                                        _ => val_p.rest
                                    }) {
                                        Err(e) => Result.err(e)
                                        Ok(cont_p) => Result.ok(ExprParse { expr: EBind(vname, val_p.expr, cont_p.expr)  rest: cont_p.rest })
                                    }
                                }
                            }
                        }
                    }
                }
                _ => Result.err("expected identifier after bind")
            }
        }
        Some(TkFor) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(vname)) => {
                    bind rest2 <- advance(rest1);
                    match expect_tok(rest2, TkIn) {
                        Err(e) => Result.err(e)
                        Ok(rest3) => {
                            match parse_expr(rest3) {
                                Err(e) => Result.err(e)
                                Ok(iter_p) => {
                                    match expect_tok(iter_p.rest, TkLBrace) {
                                        Err(e) => Result.err(e)
                                        Ok(rest4) => {
                                            match parse_block_inner(rest4) {
                                                Err(e) => Result.err(e)
                                                Ok(body_p) => {
                                                    match expect_tok(body_p.rest, TkRBrace) {
                                                        Err(e) => Result.err(e)
                                                        Ok(rest5) => {
                                                            match parse_block_inner(match peek(rest5) {
                                                                Some(TkSemicolon) => advance(rest5)
                                                                _ => rest5
                                                            }) {
                                                                Err(e) => Result.err(e)
                                                                Ok(cont_p) => Result.ok(ExprParse { expr: EBind("$for_ignore", ECall("List", "map", EArgList(ELambda(vname, body_p.expr), EArgList(iter_p.expr, EArgNil))), cont_p.expr)  rest: cont_p.rest })
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                _ => Result.err("expected identifier after for")
            }
        }
        Some(TkYield) => {
            bind rest1 <- advance(toks);
            match parse_expr(rest1) {
                Err(e) => Result.err(e)
                Ok(yield_p) => {
                    match peek(yield_p.rest) {
                        Some(TkSemicolon) => {
                            match parse_block_inner(advance(yield_p.rest)) {
                                Err(e) => Result.err(e)
                                Ok(cont_p) => Result.ok(ExprParse { expr: EBlock(EYield(yield_p.expr), cont_p.expr)  rest: cont_p.rest })
                            }
                        }
                        _ => Result.ok(ExprParse { expr: EYield(yield_p.expr)  rest: yield_p.rest })
                    }
                }
            }
        }
        _ => parse_expr(toks)
    }
}

fn parse_postfix(expr: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkDot) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(field)) => {
                    bind rest2 <- advance(rest1);
                    parse_postfix(EAccess(expr, field), rest2)
                }
                _ => Result.err("expected field name after dot")
            }
        }
        Some(TkQuestion) => {
            bind rest1 <- advance(toks);
            parse_postfix(EQuestion(expr), rest1)
        }
        _ => Result.ok(ExprParse { expr: expr  rest: toks })
    }
}

fn parse_primary(toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        None => Result.err("unexpected end of input")
        Some(TkInt(n)) => Result.ok(ExprParse { expr: ELit(LInt(n))  rest: advance(toks) })
        Some(TkFloat(f)) => Result.ok(ExprParse { expr: ELit(LFloat(f))  rest: advance(toks) })
        Some(TkStr(s)) => Result.ok(ExprParse { expr: ELit(LStr(s))  rest: advance(toks) })
        Some(TkTrue) => Result.ok(ExprParse { expr: ELit(LBool(true))  rest: advance(toks) })
        Some(TkFalse) => Result.ok(ExprParse { expr: ELit(LBool(false))  rest: advance(toks) })
        Some(TkLParen) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkRParen) => Result.ok(ExprParse { expr: ELit(LUnit)  rest: advance(rest1) })
                _ => {
                    match parse_expr(rest1) {
                        Err(e) => Result.err(e)
                        Ok(inner) => {
                            match expect_tok(inner.rest, TkRParen) {
                                Err(e) => Result.err(e)
                                Ok(rest2) => Result.ok(ExprParse { expr: inner.expr  rest: rest2 })
                            }
                        }
                    }
                }
            }
        }
        Some(TkIf) => {
            bind rest1 <- advance(toks);
            match parse_expr(rest1) {
                Err(e) => Result.err(e)
                Ok(cond_p) => {
                    match expect_tok(cond_p.rest, TkLBrace) {
                        Err(e) => Result.err(e)
                        Ok(rest2) => {
                            match parse_block_inner(rest2) {
                                Err(e) => Result.err(e)
                                Ok(then_p) => {
                                    match expect_tok(then_p.rest, TkRBrace) {
                                        Err(e) => Result.err(e)
                                        Ok(rest3) => {
                                            match expect_tok(rest3, TkElse) {
                                                Err(e) => Result.err(e)
                                                Ok(rest4) => {
                                                    match expect_tok(rest4, TkLBrace) {
                                                        Err(e) => Result.err(e)
                                                        Ok(rest5) => {
                                                            match parse_block_inner(rest5) {
                                                                Err(e) => Result.err(e)
                                                                Ok(else_p) => {
                                                                    match expect_tok(else_p.rest, TkRBrace) {
                                                                        Err(e) => Result.err(e)
                                                                        Ok(rest6) => Result.ok(ExprParse { expr: EIf(cond_p.expr, then_p.expr, else_p.expr)  rest: rest6 })
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        Some(TkMatch) => {
            bind rest1 <- advance(toks);
            match parse_expr(rest1) {
                Err(e) => Result.err(e)
                Ok(scrut_p) => {
                    match expect_tok(scrut_p.rest, TkLBrace) {
                        Err(e) => Result.err(e)
                        Ok(rest2) => {
                            match parse_arms(rest2, EArmNil) {
                                Err(e) => Result.err(e)
                                Ok(arms_p) => {
                                    match expect_tok(arms_p.rest, TkRBrace) {
                                        Err(e) => Result.err(e)
                                        Ok(rest3) => Result.ok(ExprParse { expr: EMatch(scrut_p.expr, arms_p.expr)  rest: rest3 })
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        Some(TkPipe) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(param)) => {
                    bind rest2 <- advance(rest1);
                    parse_lambda_rest(param, rest2)
                }
                _ => Result.err("expected lambda parameter")
            }
        }
        Some(TkLBrace) => {
            bind rest1 <- advance(toks);
            match parse_block_inner(rest1) {
                Err(e) => Result.err(e)
                Ok(inner) => {
                    match expect_tok(inner.rest, TkRBrace) {
                        Err(e) => Result.err(e)
                        Ok(rest2) => Result.ok(ExprParse { expr: inner.expr  rest: rest2 })
                    }
                }
            }
        }
        Some(TkCollect) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkLBrace) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    match parse_block_inner(rest2) {
                        Err(e) => Result.err(e)
                        Ok(inner) => {
                            match expect_tok(inner.rest, TkRBrace) {
                                Err(e) => Result.err(e)
                                Ok(rest3) => Result.ok(ExprParse { expr: ECollect(inner.expr)  rest: rest3 })
                            }
                        }
                    }
                }
            }
        }
        Some(TkIdent(name)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkDot) => {
                    bind rest2 <- advance(rest1);
                    match peek(rest2) {
                        Some(TkIdent(fname)) => {
                            bind rest3 <- advance(rest2);
                            match peek(rest3) {
                                Some(TkLParen) => {
                                    bind rest4 <- advance(rest3);
                                    match parse_args(rest4, EArgNil) {
                                        Err(e) => Result.err(e)
                                        Ok(args_p) => {
                                            match expect_tok(args_p.rest, TkRParen) {
                                                Err(e) => Result.err(e)
                                                Ok(rest5) => parse_postfix(ECall(name, fname, args_p.expr), rest5)
                                            }
                                        }
                                    }
                                }
                                _ => parse_postfix(EAccess(EVar(name), fname), rest3)
                            }
                        }
                        _ => Result.err("expected field name after dot")
                    }
                }
                Some(TkLParen) => {
                    bind rest2 <- advance(rest1);
                    match parse_args(rest2, EArgNil) {
                        Err(e) => Result.err(e)
                        Ok(args_p) => {
                            match expect_tok(args_p.rest, TkRParen) {
                                Err(e) => Result.err(e)
                                Ok(rest3) => parse_postfix(ECall("", name, args_p.expr), rest3)
                            }
                        }
                    }
                }
                Some(TkLBrace) => {
                    if String.contains("ABCDEFGHIJKLMNOPQRSTUVWXYZ", String.slice(name, 0, 1)) {
                        bind rest2 <- advance(rest1);
                        match parse_fields(rest2, EFieldNil) {
                            Err(e) => Result.err(e)
                            Ok(fields_p) => {
                                match expect_tok(fields_p.rest, TkRBrace) {
                                    Err(e) => Result.err(e)
                                    Ok(rest3) => Result.ok(ExprParse { expr: ERecordLit(name, fields_p.expr)  rest: rest3 })
                                }
                            }
                        }
                    } else {
                        parse_postfix(EVar(name), rest1)
                    }
                }
                _ => parse_postfix(EVar(name), rest1)
            }
        }
        _ => Result.err("unexpected token in expression")
    }
}

fn parse_mul(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_primary(toks) {
        Ok(lhs) => parse_mul_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_mul_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkStar) => {
            match parse_primary(advance(toks)) {
                Ok(rhs) => parse_mul_rest(EBinOp(OpMul, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        Some(TkSlash) => {
            match parse_primary(advance(toks)) {
                Ok(rhs) => parse_mul_rest(EBinOp(OpDiv, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        Some(TkPercent) => {
            match parse_primary(advance(toks)) {
                Ok(rhs) => parse_mul_rest(EBinOp(OpMod, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_add(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_mul(toks) {
        Ok(lhs) => parse_add_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_add_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkPlus) => {
            match parse_mul(advance(toks)) {
                Ok(rhs) => parse_add_rest(EBinOp(OpAdd, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        Some(TkMinus) => {
            match parse_mul(advance(toks)) {
                Ok(rhs) => parse_add_rest(EBinOp(OpSub, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_cmp(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_add(toks) {
        Ok(lhs) => parse_cmp_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_cmp_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkEqEq) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpEq, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        Some(TkBangEq) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpNeq, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        Some(TkLt) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpLt, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        Some(TkGt) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpGt, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        Some(TkLtEq) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpLtEq, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        Some(TkGtEq) => {
            match parse_add(advance(toks)) {
                Ok(rhs) => Result.ok(ExprParse { expr: EBinOp(OpGtEq, lhs, rhs.expr)  rest: rhs.rest })
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_and(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_cmp(toks) {
        Ok(lhs) => parse_and_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_and_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkAmpAmp) => {
            match parse_cmp(advance(toks)) {
                Ok(rhs) => parse_and_rest(EBinOp(OpAnd, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_or(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_and(toks) {
        Ok(lhs) => parse_or_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_or_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkPipePipe) => {
            match parse_and(advance(toks)) {
                Ok(rhs) => parse_or_rest(EBinOp(OpOr, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_lambda_rest(param: String, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkComma) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(next_param)) => {
                    bind rest2 <- advance(rest1);
                    match parse_lambda_rest(next_param, rest2) {
                        Err(e) => Result.err(e)
                        Ok(inner_p) => Result.ok(ExprParse { expr: ELambda(param, inner_p.expr)  rest: inner_p.rest })
                    }
                }
                _ => Result.err("expected lambda parameter after comma")
            }
        }
        _ => {
            match expect_tok(toks, TkPipe) {
                Err(e) => Result.err(e)
                Ok(rest3) => {
                    match parse_expr(rest3) {
                        Err(e) => Result.err(e)
                        Ok(body_p) => Result.ok(ExprParse { expr: ELambda(param, body_p.expr)  rest: body_p.rest })
                    }
                }
            }
        }
    }
}

fn parse_null_coalesce(toks: List<Token>) -> Result<ExprParse, String> {
    match parse_or(toks) {
        Ok(lhs) => parse_null_coalesce_rest(lhs.expr, lhs.rest)
        Err(e) => Result.err(e)
    }
}

fn parse_null_coalesce_rest(lhs: Expr, toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkQuestionQuestion) => {
            match parse_or(advance(toks)) {
                Ok(rhs) => parse_null_coalesce_rest(EBinOp(OpNullCoalesce, lhs, rhs.expr), rhs.rest)
                Err(e) => Result.err(e)
            }
        }
        _ => Result.ok(ExprParse { expr: lhs  rest: toks })
    }
}

fn parse_expr(toks: List<Token>) -> Result<ExprParse, String> {
    parse_null_coalesce(toks)
}

fn parse_param(toks: List<Token>) -> Result<ParamParse, String> {
    match peek(toks) {
        Some(TkIdent(pname)) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkColon) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    match parse_type_expr(rest2) {
                        Err(e) => Result.err(e)
                        Ok(ty_p) => Result.ok(ParamParse { param: Param { name: pname  ty: ty_p.ty }  rest: ty_p.rest })
                    }
                }
            }
        }
        _ => Result.err("expected parameter name")
    }
}

fn parse_params_acc(toks: List<Token>, acc: List<Param>) -> Result<ParamsParse, String> {
    match peek(toks) {
        Some(TkRParen) => Result.ok(ParamsParse { params: acc  rest: toks })
        Some(TkRBrace) => Result.ok(ParamsParse { params: acc  rest: toks })
        Some(TkEof) => Result.err("unterminated parameter list")
        _ => {
            match parse_param(toks) {
                Err(e) => Result.err(e)
                Ok(p) => {
                    parse_params_acc(match peek(p.rest) {
                        Some(TkComma) => advance(p.rest)
                        _ => p.rest
                    }, List.push(acc, p.param))
                }
            }
        }
    }
}

fn parse_params(toks: List<Token>) -> Result<ParamsParse, String> {
    bind empty <- List.take_while(List.singleton(Param { name: ""  ty: TeSimple("") }), |v| false);
    parse_params_acc(toks, empty)
}

fn parse_fn_def_finish(is_pub: Bool, fname: String, params_p: ParamsParse, ret_p: TypeExprParse, body_p: ExprParse) -> Result<FnDefParse, String> {
    match expect_tok(body_p.rest, TkRBrace) {
        Err(e) => Result.err(e)
        Ok(rest7) => Result.ok(FnDefParse { fn_def: FnDef { is_public: is_pub  name: fname  params: params_p.params  ret: ret_p.ty  body: body_p.expr  doc: "" }  rest: rest7 })
    }
}

fn parse_fn_def_after_body(is_pub: Bool, fname: String, params_p: ParamsParse, ret_p: TypeExprParse, rest6: List<Token>) -> Result<FnDefParse, String> {
    match parse_block_inner(rest6) {
        Err(e) => Result.err(e)
        Ok(body_p) => parse_fn_def_finish(is_pub, fname, params_p, ret_p, body_p)
    }
}

fn parse_fn_def_after_ret(is_pub: Bool, fname: String, params_p: ParamsParse, ret_p: TypeExprParse) -> Result<FnDefParse, String> {
    bind empty_effs <- empty_string_list();
    bind effs_p <- parse_effects_acc(ret_p.rest, empty_effs);
    match expect_tok(effs_p.rest, TkLBrace) {
        Err(e) => Result.err(e)
        Ok(rest6) => parse_fn_def_after_body(is_pub, fname, params_p, ret_p, rest6)
    }
}

fn parse_fn_def_after_params(is_pub: Bool, fname: String, params_p: ParamsParse) -> Result<FnDefParse, String> {
    match expect_tok(params_p.rest, TkRParen) {
        Err(e) => Result.err(e)
        Ok(rest4) => {
            match List.first(rest4) {
                Some(TkArrow) => {
                    match expect_tok(rest4, TkArrow) {
                        Err(e) => Result.err(e)
                        Ok(rest5) => {
                            match parse_type_expr(rest5) {
                                Err(e) => Result.err(e)
                                Ok(ret_p) => parse_fn_def_after_ret(is_pub, fname, params_p, ret_p)
                            }
                        }
                    }
                }
                _ => parse_fn_def_after_ret(is_pub, fname, params_p, TypeExprParse { ty: TeSimple("")  rest: rest4 })
            }
        }
    }
}

fn parse_fn_def_after_name(rest2: List<Token>, is_pub: Bool, fname: String) -> Result<FnDefParse, String> {
    match expect_tok(rest2, TkLParen) {
        Err(e) => Result.err(e)
        Ok(rest3) => {
            match parse_params(rest3) {
                Err(e) => Result.err(e)
                Ok(params_p) => parse_fn_def_after_params(is_pub, fname, params_p)
            }
        }
    }
}

fn parse_fn_def(toks: List<Token>, is_pub: Bool) -> Result<FnDefParse, String> {
    match expect_tok(toks, TkFn) {
        Err(e) => Result.err(e)
        Ok(rest1) => {
            match peek(rest1) {
                Some(TkIdent(fname)) => {
                    bind rest2 <- advance(rest1);
                    parse_fn_def_after_name(rest2, is_pub, fname)
                }
                _ => Result.err("expected function name")
            }
        }
    }
}

fn parse_variant_payload(vname: String, rest3: List<Token>) -> Result<VariantDefParse, String> {
    match parse_type_expr(rest3) {
        Err(e) => Result.err(e)
        Ok(ty_p) => {
            match skip_extra_type_args(ty_p.rest) {
                Err(e) => Result.err(e)
                Ok(rest_mid) => {
                    match expect_tok(rest_mid, TkRParen) {
                        Err(e) => Result.err(e)
                        Ok(rest4) => Result.ok(VariantDefParse { variant: VariantDef { name: vname  payload: Option.some(ty_p.ty) }  rest: rest4 })
                    }
                }
            }
        }
    }
}

fn parse_variant(toks: List<Token>) -> Result<VariantDefParse, String> {
    match expect_tok(toks, TkPipe) {
        Err(e) => Result.err(e)
        Ok(rest1) => {
            match peek(rest1) {
                Some(TkIdent(vname)) => {
                    bind rest2 <- advance(rest1);
                    match peek(rest2) {
                        Some(TkLParen) => {
                            bind rest3 <- advance(rest2);
                            parse_variant_payload(vname, rest3)
                        }
                        _ => Result.ok(VariantDefParse { variant: VariantDef { name: vname  payload: Option.none() }  rest: rest2 })
                    }
                }
                _ => Result.err("expected variant name after |")
            }
        }
    }
}

fn parse_variants_acc(toks: List<Token>, acc: List<VariantDef>) -> Result<VariantsParse, String> {
    match peek(toks) {
        Some(TkPipe) => {
            match parse_variant(toks) {
                Err(e) => Result.err(e)
                Ok(v) => parse_variants_acc(v.rest, List.push(acc, v.variant))
            }
        }
        _ => Result.ok(VariantsParse { variants: acc  rest: toks })
    }
}

fn parse_variants(toks: List<Token>) -> Result<VariantsParse, String> {
    bind empty <- List.take_while(List.singleton(VariantDef { name: ""  payload: Option.none() }), |v| false);
    parse_variants_acc(toks, empty)
}

fn parse_type_def_variant_branch(tname: String, rest3: List<Token>) -> Result<TypeDefParse, String> {
    bind empty_params <- List.take_while(List.singleton(Param { name: ""  ty: TeSimple("") }), |v| false);
    match parse_variants(rest3) {
        Err(e) => Result.err(e)
        Ok(vs) => Result.ok(TypeDefParse { type_def: TypeDef { name: tname  is_record: false  variants: vs.variants  fields: empty_params  doc: "" }  rest: vs.rest })
    }
}

fn parse_type_def_record_branch(tname: String, rest3: List<Token>) -> Result<TypeDefParse, String> {
    bind rest4 <- advance(rest3);
    bind empty_variants <- List.take_while(List.singleton(VariantDef { name: ""  payload: Option.none() }), |v| false);
    match parse_params(rest4) {
        Err(e) => Result.err(e)
        Ok(fields_p) => {
            match expect_tok(fields_p.rest, TkRBrace) {
                Err(e) => Result.err(e)
                Ok(rest5) => Result.ok(TypeDefParse { type_def: TypeDef { name: tname  is_record: true  variants: empty_variants  fields: fields_p.params  doc: "" }  rest: rest5 })
            }
        }
    }
}

fn parse_type_def_after_eq(tname: String, rest3: List<Token>) -> Result<TypeDefParse, String> {
    match peek(rest3) {
        Some(TkPipe) => parse_type_def_variant_branch(tname, rest3)
        Some(TkLBrace) => parse_type_def_record_branch(tname, rest3)
        _ => Result.err("expected = | variants or = { fields } in type definition")
    }
}

fn parse_type_def(toks: List<Token>) -> Result<TypeDefParse, String> {
    match expect_tok(toks, TkType) {
        Err(e) => Result.err(e)
        Ok(rest1) => {
            match peek(rest1) {
                Some(TkIdent(tname)) => {
                    bind rest2 <- advance(rest1);
                    match expect_tok(rest2, TkEq) {
                        Err(e) => Result.err(e)
                        Ok(rest3) => parse_type_def_after_eq(tname, rest3)
                    }
                }
                _ => Result.err("expected type name")
            }
        }
    }
}

fn parse_type_or_wrapper_item(toks: List<Token>) -> Result<ItemParse, String> {
    match expect_tok(toks, TkType) {
        Err(e) => Result.err(e)
        Ok(rest1) => {
            match peek(rest1) {
                Some(TkIdent(tname)) => {
                    bind rest2 <- advance(rest1);
                    match peek(rest2) {
                        Some(TkLParen) => {
                            bind rest3 <- advance(rest2);
                            match parse_type_expr(rest3) {
                                Err(e) => Result.err(e)
                                Ok(inner_p) => {
                                    match expect_tok(inner_p.rest, TkRParen) {
                                        Err(e) => Result.err(e)
                                        Ok(rest4) => {
                                            match parse_with_clause(rest4) {
                                                Err(e) => Result.err(e)
                                                Ok(with_p) => {
                                                    match parse_where_clause(with_p.rest) {
                                                        Err(e) => Result.err(e)
                                                        Ok(where_p) => {
                                                            Result.ok(ItemParse { item: IWrapper(WrapperDef { name: tname  inner: type_expr_to_str(inner_p.ty)  where_pred: where_p.expr  with_impls: with_p.impls  doc: "" })  rest: where_p.rest })
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        Some(TkEq) => {
                            bind rest3 <- advance(rest2);
                            match parse_type_def_after_eq(tname, rest3) {
                                Err(e) => Result.err(e)
                                Ok(td) => Result.ok(ItemParse { item: IType(td.type_def)  rest: td.rest })
                            }
                        }
                        _ => Result.err("expected '=' or '(' after type name")
                    }
                }
                _ => Result.err("expected type name")
            }
        }
    }
}

fn parse_test_item_after_name(tname: String, rest2: List<Token>) -> Result<ItemParse, String> {
    match expect_tok(rest2, TkLBrace) {
        Err(e) => Result.err(e)
        Ok(rest3) => {
            match parse_block_inner(rest3) {
                Err(e) => Result.err(e)
                Ok(body_p) => {
                    match expect_tok(body_p.rest, TkRBrace) {
                        Err(e) => Result.err(e)
                        Ok(rest4) => Result.ok(ItemParse { item: ITest(TestDef { name: tname  body: body_p.expr })  rest: rest4 })
                    }
                }
            }
        }
    }
}

fn empty_string_list() -> List<String> {
    List.drop_while(List.singleton(""), |v| true)
}

type WithClauseParse = {
    impls: List<String>
    rest: List<Token>
}

fn parse_with_idents(toks: List<Token>, acc: List<String>) -> Result<WithClauseParse, String> {
    match peek(toks) {
        Some(TkIdent(iname)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkComma) => parse_with_idents(advance(rest1), List.push(acc, iname))
                _ => Result.ok(WithClauseParse { impls: List.push(acc, iname)  rest: rest1 })
            }
        }
        _ => Result.err("expected interface name after 'with'")
    }
}

fn parse_with_clause(toks: List<Token>) -> Result<WithClauseParse, String> {
    match peek(toks) {
        Some(TkWith) => {
            bind rest1 <- advance(toks);
            bind empty <- empty_string_list();
            parse_with_idents(rest1, empty)
        }
        _ => {
            bind empty <- empty_string_list();
            Result.ok(WithClauseParse { impls: empty  rest: toks })
        }
    }
}

fn parse_where_clause(toks: List<Token>) -> Result<ExprParse, String> {
    match peek(toks) {
        Some(TkWhere) => {
            bind rest1 <- advance(toks);
            parse_expr(rest1)
        }
        _ => Result.ok(ExprParse { expr: ELit(LUnit)  rest: toks })
    }
}

fn parse_effects_acc(toks: List<Token>, acc: List<String>) -> EffectsParse {
    match peek(toks) {
        Some(TkBang) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkIdent(ename)) => {
                    bind rest2 <- advance(rest1);
                    parse_effects_acc(rest2, List.push(acc, ename))
                }
                _ => EffectsParse { effects: acc  rest: toks }
            }
        }
        _ => EffectsParse { effects: acc  rest: toks }
    }
}

fn parse_par_names_acc(toks: List<Token>, acc: List<String>) -> Result<ParNamesParse, String> {
    match peek(toks) {
        Some(TkIdent(sname)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkComma) => {
                    bind rest2 <- advance(rest1);
                    parse_par_names_acc(rest2, List.push(acc, sname))
                }
                _ => Result.ok(ParNamesParse { names: List.push(acc, sname)  rest: rest1 })
            }
        }
        _ => Result.err("expected stage name in par [...]")
    }
}

fn parse_seq_step(toks: List<Token>) -> Result<SeqStepParse, String> {
    match peek(toks) {
        Some(TkPar) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkLBracket) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    bind empty_names <- List.empty();
                    match parse_par_names_acc(rest2, empty_names) {
                        Err(e) => Result.err(e)
                        Ok(names_p) => {
                            match expect_tok(names_p.rest, TkRBracket) {
                                Err(e) => Result.err(e)
                                Ok(rest3) => Result.ok(SeqStepParse { step: SPar(names_p.names)  rest: rest3 })
                            }
                        }
                    }
                }
            }
        }
        Some(TkIdent(sname)) => {
            bind rest1 <- advance(toks);
            Result.ok(SeqStepParse { step: SStage(sname)  rest: rest1 })
        }
        _ => Result.err("expected stage name or par [...] in seq pipeline")
    }
}

fn parse_seq_pipeline_acc(toks: List<Token>, acc: List<SeqStep>) -> Result<PipelineStepsParse, String> {
    match parse_seq_step(toks) {
        Err(e) => Result.err(e)
        Ok(step_p) => {
            bind new_acc <- List.push(acc, step_p.step);
            match peek(step_p.rest) {
                Some(TkPipeGt) => {
                    bind rest2 <- advance(step_p.rest);
                    parse_seq_pipeline_acc(rest2, new_acc)
                }
                _ => Result.ok(PipelineStepsParse { stages: new_acc  rest: step_p.rest })
            }
        }
    }
}

fn parse_stage_def_with_body(sname: String, is_pub: Bool, param_ty: TypeExpr, ret_ty: TypeExpr, effects: List<String>, rest4: List<Token>) -> Result<StageDefParse, String> {
    match parse_expr(rest4) {
        Err(e) => Result.err(e)
        Ok(body_p) => {
            bind sd <- StageDef { is_public: is_pub  is_abstract: false  name: sname  param_ty: param_ty  ret_ty: ret_ty  effects: effects  body: Option.some(body_p.expr)  doc: "" };
            Result.ok(StageDefParse { stage_def: sd  rest: body_p.rest })
        }
    }
}

fn parse_stage_def_effects_done(sname: String, is_pub: Bool, is_abstract: Bool, param_ty: TypeExpr, ret_ty: TypeExpr, effs_p: EffectsParse) -> Result<StageDefParse, String> {
    if is_abstract {
        bind sd <- StageDef { is_public: is_pub  is_abstract: true  name: sname  param_ty: param_ty  ret_ty: ret_ty  effects: effs_p.effects  body: Option.none()  doc: "" };
        Result.ok(StageDefParse { stage_def: sd  rest: effs_p.rest })
    } else {
        match expect_tok(effs_p.rest, TkEq) {
            Err(e) => Result.err(e)
            Ok(rest4) => parse_stage_def_with_body(sname, is_pub, param_ty, ret_ty, effs_p.effects, rest4)
        }
    }
}

fn parse_stage_def_ret_done(sname: String, is_pub: Bool, is_abstract: Bool, param_ty: TypeExpr, ret_p: TypeExprParse) -> Result<StageDefParse, String> {
    bind empty_effs <- empty_string_list();
    bind effs_p <- parse_effects_acc(ret_p.rest, empty_effs);
    parse_stage_def_effects_done(sname, is_pub, is_abstract, param_ty, ret_p.ty, effs_p)
}

fn parse_stage_def_param_done(sname: String, is_pub: Bool, is_abstract: Bool, param_p: TypeExprParse) -> Result<StageDefParse, String> {
    match expect_tok(param_p.rest, TkArrow) {
        Err(e) => Result.err(e)
        Ok(rest3) => {
            match parse_type_expr(rest3) {
                Err(e) => Result.err(e)
                Ok(ret_p) => parse_stage_def_ret_done(sname, is_pub, is_abstract, param_p.ty, ret_p)
            }
        }
    }
}

fn parse_stage_def(toks: List<Token>, is_pub: Bool, is_abstract: Bool) -> Result<StageDefParse, String> {
    match peek(toks) {
        Some(TkIdent(sname)) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkColon) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    match parse_type_expr(rest2) {
                        Err(e) => Result.err(e)
                        Ok(param_p) => parse_stage_def_param_done(sname, is_pub, is_abstract, param_p)
                    }
                }
            }
        }
        _ => Result.err("expected stage name")
    }
}

fn parse_seq_def(toks: List<Token>, is_pub: Bool, is_abstract: Bool) -> Result<SeqDefParse, String> {
    match peek(toks) {
        Some(TkIdent(sname)) => {
            bind rest1 <- advance(toks);
            if is_abstract {
                bind empty_stages <- List.empty();
                bind sd <- SeqDef { is_public: is_pub  is_abstract: true  name: sname  stages: empty_stages  doc: "" };
                Result.ok(SeqDefParse { seq_def: sd  rest: rest1 })
            } else {
                match expect_tok(rest1, TkEq) {
                    Err(e) => Result.err(e)
                    Ok(rest2) => {
                        bind empty_stages <- List.empty();
                        match parse_seq_pipeline_acc(rest2, empty_stages) {
                            Err(e) => Result.err(e)
                            Ok(pipe_p) => {
                                bind sd <- SeqDef { is_public: is_pub  is_abstract: false  name: sname  stages: pipe_p.stages  doc: "" };
                                Result.ok(SeqDefParse { seq_def: sd  rest: pipe_p.rest })
                            }
                        }
                    }
                }
            }
        }
        _ => Result.err("expected seq name")
    }
}

fn skip_interface_type_tokens(toks: List<Token>) -> List<Token> {
    match peek(toks) {
        None => toks
        Some(TkRBrace) => toks
        Some(TkEof) => toks
        Some(TkIdent(_)) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkColon) => toks
                _ => skip_interface_type_tokens(rest1)
            }
        }
        _ => skip_interface_type_tokens(advance(toks))
    }
}

fn parse_interface_method_decl(toks: List<Token>) -> Result<InterfaceMethodDeclParse, String> {
    match peek(toks) {
        Some(TkIdent(mname)) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkColon) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    bind rest3 <- skip_interface_type_tokens(rest2);
                    Result.ok(InterfaceMethodDeclParse { method: InterfaceMethodDecl { name: mname  ty: "" }  rest: rest3 })
                }
            }
        }
        _ => Result.err("expected interface method name")
    }
}

fn parse_interface_methods_acc(toks: List<Token>, acc: List<InterfaceMethodDecl>) -> Result<InterfaceMethodDeclsParse, String> {
    match peek(toks) {
        Some(TkRBrace) => Result.ok(InterfaceMethodDeclsParse { methods: acc  rest: toks })
        Some(TkEof) => Result.err("unterminated interface body")
        _ => {
            match parse_interface_method_decl(toks) {
                Err(e) => Result.err(e)
                Ok(mp) => parse_interface_methods_acc(mp.rest, List.push(acc, mp.method))
            }
        }
    }
}

fn parse_interface_item(toks: List<Token>) -> Result<ItemParse, String> {
    match peek(toks) {
        Some(TkIdent(iname)) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkLBrace) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    match parse_interface_methods_acc(rest2, List.empty()) {
                        Err(e) => Result.err(e)
                        Ok(mp) => {
                            match expect_tok(mp.rest, TkRBrace) {
                                Err(e) => Result.err(e)
                                Ok(rest3) => Result.ok(ItemParse { item: IInterface(InterfaceDef { name: iname  methods: mp.methods })  rest: rest3 })
                            }
                        }
                    }
                }
            }
        }
        _ => Result.err("expected interface name")
    }
}

fn parse_impl_methods_acc(toks: List<Token>, acc: List<FnDef>) -> Result<ImplMethodsParse, String> {
    match peek(toks) {
        Some(TkRBrace) => Result.ok(ImplMethodsParse { methods: acc  rest: toks })
        Some(TkEof) => Result.err("unterminated impl body")
        Some(TkFn) => {
            match parse_fn_def(toks, false) {
                Err(e) => Result.err(e)
                Ok(fd) => parse_impl_methods_acc(fd.rest, List.push(acc, fd.fn_def))
            }
        }
        _ => Result.err("expected fn or } in impl body")
    }
}

fn parse_impl_item(toks: List<Token>) -> Result<ItemParse, String> {
    match peek(toks) {
        Some(TkIdent(iface_name)) => {
            bind rest1 <- advance(toks);
            match expect_tok(rest1, TkFor) {
                Err(e) => Result.err(e)
                Ok(rest2) => {
                    match peek(rest2) {
                        Some(TkIdent(type_name)) => {
                            bind rest3 <- advance(rest2);
                            match expect_tok(rest3, TkLBrace) {
                                Err(e) => Result.err(e)
                                Ok(rest4) => {
                                    match parse_impl_methods_acc(rest4, List.empty()) {
                                        Err(e) => Result.err(e)
                                        Ok(mp) => {
                                            match expect_tok(mp.rest, TkRBrace) {
                                                Err(e) => Result.err(e)
                                                Ok(rest5) => {
                                                    bind iface_names <- List.singleton(iface_name);
                                                    Result.ok(ItemParse { item: IImpl(ImplDeclDef { interface_names: iface_names  type_name: type_name  methods: mp.methods })  rest: rest5 })
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        _ => Result.err("expected type name after for")
                    }
                }
            }
        }
        _ => Result.err("expected interface name after impl")
    }
}

fn parse_item(toks: List<Token>) -> Result<ItemParse, String> {
    match peek(toks) {
        Some(TkPublic) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkFn) => {
                    match parse_fn_def(rest1, true) {
                        Err(e) => Result.err(e)
                        Ok(fd) => Result.ok(ItemParse { item: IFn(fd.fn_def)  rest: fd.rest })
                    }
                }
                Some(TkStage) => {
                    bind rest2 <- advance(rest1);
                    match parse_stage_def(rest2, true, false) {
                        Err(e) => Result.err(e)
                        Ok(sd) => Result.ok(ItemParse { item: IStage(sd.stage_def)  rest: sd.rest })
                    }
                }
                Some(TkSeq) => {
                    bind rest2 <- advance(rest1);
                    match parse_seq_def(rest2, true, false) {
                        Err(e) => Result.err(e)
                        Ok(sd) => Result.ok(ItemParse { item: ISeq(sd.seq_def)  rest: sd.rest })
                    }
                }
                _ => Result.err("expected fn, stage, or seq after public")
            }
        }
        Some(TkFn) => {
            match parse_fn_def(toks, false) {
                Err(e) => Result.err(e)
                Ok(fd) => Result.ok(ItemParse { item: IFn(fd.fn_def)  rest: fd.rest })
            }
        }
        Some(TkType) => {
            parse_type_or_wrapper_item(toks)
        }
        Some(TkTest) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkStr(tname)) => {
                    bind rest2 <- advance(rest1);
                    parse_test_item_after_name(tname, rest2)
                }
                _ => Result.err("expected test name string")
            }
        }
        Some(TkStage) => {
            bind rest1 <- advance(toks);
            match parse_stage_def(rest1, false, false) {
                Err(e) => Result.err(e)
                Ok(sd) => Result.ok(ItemParse { item: IStage(sd.stage_def)  rest: sd.rest })
            }
        }
        Some(TkSeq) => {
            bind rest1 <- advance(toks);
            match parse_seq_def(rest1, false, false) {
                Err(e) => Result.err(e)
                Ok(sd) => Result.ok(ItemParse { item: ISeq(sd.seq_def)  rest: sd.rest })
            }
        }
        Some(TkAbstract) => {
            bind rest1 <- advance(toks);
            match peek(rest1) {
                Some(TkStage) => {
                    bind rest2 <- advance(rest1);
                    match parse_stage_def(rest2, false, true) {
                        Err(e) => Result.err(e)
                        Ok(sd) => Result.ok(ItemParse { item: IStage(sd.stage_def)  rest: sd.rest })
                    }
                }
                Some(TkSeq) => {
                    bind rest2 <- advance(rest1);
                    match parse_seq_def(rest2, false, true) {
                        Err(e) => Result.err(e)
                        Ok(sd) => Result.ok(ItemParse { item: ISeq(sd.seq_def)  rest: sd.rest })
                    }
                }
                _ => Result.err("expected stage or seq after abstract")
            }
        }
        Some(TkInterface) => {
            bind rest1 <- advance(toks);
            parse_interface_item(rest1)
        }
        Some(TkImpl) => {
            bind rest1 <- advance(toks);
            parse_impl_item(rest1)
        }
        _ => Result.err("expected fn, type, public, stage, seq, abstract, test, interface, or impl")
    }
}

type DocCollect = {
    doc: String
    rest: List<Token>
}

fn collect_doc(toks: List<Token>, acc: String) -> DocCollect {
    match peek(toks) {
        Some(TkDocComment(text)) => {
            bind rest1 <- advance(toks);
            bind sep <- if acc == "" {
                ""
            } else {
                "\n"
            };
            collect_doc(rest1, String.concat(acc, String.concat(sep, text)))
        }
        _ => DocCollect { doc: acc  rest: toks }
    }
}

fn set_item_doc(item: Item, doc: String) -> Item {
    match item {
        IFn(fd) => IFn(FnDef { is_public: fd.is_public  name: fd.name  params: fd.params  ret: fd.ret  body: fd.body  doc: doc })
        IType(td) => IType(TypeDef { name: td.name  is_record: td.is_record  variants: td.variants  fields: td.fields  doc: doc })
        IStage(sd) => IStage(StageDef { is_public: sd.is_public  is_abstract: sd.is_abstract  name: sd.name  param_ty: sd.param_ty  ret_ty: sd.ret_ty  effects: sd.effects  body: sd.body  doc: doc })
        ISeq(sd) => ISeq(SeqDef { is_public: sd.is_public  is_abstract: sd.is_abstract  name: sd.name  stages: sd.stages  doc: doc })
        IWrapper(wd) => IWrapper(WrapperDef { name: wd.name  inner: wd.inner  where_pred: wd.where_pred  with_impls: wd.with_impls  doc: doc })
        ITest(td) => ITest(td)
        IInterface(_) => item
        IImpl(_) => item
    }
}

fn parse_items_acc(toks: List<Token>, acc: List<Item>) -> Result<ItemsParse, String> {
    match peek(toks) {
        Some(TkEof) => Result.ok(ItemsParse { items: acc  rest: toks })
        None => Result.ok(ItemsParse { items: acc  rest: toks })
        _ => {
            bind dc <- collect_doc(toks, "");
            match parse_item(dc.rest) {
                Err(e) => Result.err(e)
                Ok(item_p) => {
                    bind item_with_doc <- set_item_doc(item_p.item, dc.doc);
                    parse_items_acc(item_p.rest, List.push(acc, item_with_doc))
                }
            }
        }
    }
}

fn parse_tokens(toks: List<Token>) -> Result<Program, String> {
    bind empty <- List.take_while(List.singleton(IFn(FnDef { is_public: false  name: ""  params: List.take_while(List.singleton(Param { name: ""  ty: TeSimple("") }), |v| false)  ret: TeSimple("")  body: ELit(LUnit)  doc: "" })), |v| false);
    match parse_items_acc(toks, empty) {
        Err(e) => Result.err(e)
        Ok(items_p) => Result.ok(Program { items: items_p.items })
    }
}

type Bc =
    | BcConst
    | BcConstUnit
    | BcConstTrue
    | BcConstFalse
    | BcLoadLocal
    | BcStoreLocal
    | BcLoadGlobal
    | BcPop
    | BcDup
    | BcSwap
    | BcMatchFail
    | BcCall
    | BcCallNamed
    | BcReturn
    | BcCollectBegin
    | BcCollectEnd
    | BcYieldValue
    | BcAdd
    | BcSub
    | BcMul
    | BcDiv
    | BcEq
    | BcNe
    | BcLt
    | BcLe
    | BcGt
    | BcGe
    | BcAnd
    | BcOr
    | BcJump
    | BcJumpIfFalse
    | BcJumpIfNotVariantC
    | BcGetField
    | BcBuildRecord
    | BcMakeClosure
    | BcMakeClosureN
    | BcGetVariantPayload

type ConstVal =
    | CVInt(Int)
    | CVFloat(Float)
    | CVStr(String)
    | CVName(String)

type KVPair = {
    first: String
    second: String
}

type CodegenCtx = {
    code: List<Int>
    consts: List<ConstVal>
    locals: List<KVPair>
    next_local: Int
    lifted: List<FnEntry>
    next_lambda: Int
    lambda_prefix: String
}

type ConstAdd = {
    ctx: CodegenCtx
    idx: Int
}

type PatDispatch = {
    ctx: CodegenCtx
    fail_offset: Int
}

type LambdaNameResult = {
    name: String
    next_lambda: Int
}

type FnEntry = {
    fname: String
    arity: Int
    local_count: Int
    code: List<Int>
    consts: List<ConstVal>
    ret_ty: String
    is_public: Bool
}

type Artifact = {
    fns: List<FnEntry>
}

type StrTable = {
    strs: List<String>
}

type InternResult = {
    table: StrTable
    idx: Int
}

type SerState = {
    str_table: StrTable
    type_bytes: List<Int>
    global_bytes: List<Int>
    fn_bytes: List<Int>
    fn_idx: Int
    global_count: Int
}

fn bc_byte(op: Bc) -> Int {
    match op {
        BcConst => 1
        BcConstUnit => 2
        BcConstTrue => 3
        BcConstFalse => 4
        BcLoadLocal => 16
        BcStoreLocal => 17
        BcLoadGlobal => 18
        BcPop => 19
        BcCall => 21
        BcCallNamed => 86
        BcReturn => 22
        BcCollectBegin => 80
        BcCollectEnd => 81
        BcYieldValue => 82
        BcAdd => 32
        BcSub => 33
        BcMul => 34
        BcDiv => 35
        BcEq => 36
        BcNe => 37
        BcLt => 38
        BcLe => 39
        BcGt => 40
        BcGe => 41
        BcAnd => 42
        BcOr => 43
        BcDup => 20
        BcSwap => 85
        BcMatchFail => 50
        BcJump => 48
        BcJumpIfFalse => 49
        BcJumpIfNotVariantC => 87
        BcGetField => 64
        BcBuildRecord => 65
        BcMakeClosure => 66
        BcMakeClosureN => 90
        BcGetVariantPayload => 67
    }
}

fn empty_ints() -> List<Int> {
    List.drop_while(List.singleton(0), |v| true)
}

fn empty_kvs() -> List<KVPair> {
    List.drop_while(List.singleton(KVPair { first: ""  second: "" }), |v| true)
}

fn empty_consts() -> List<ConstVal> {
    List.drop_while(List.singleton(CVInt(0)), |v| true)
}

fn new_ctx() -> CodegenCtx {
    bind code <- empty_ints();
    bind consts <- empty_consts();
    bind locals <- empty_kvs();
    bind lifted <- empty_fns();
    CodegenCtx { code: code  consts: consts  locals: locals  next_local: 0  lifted: lifted  next_lambda: 0  lambda_prefix: "" }
}

fn ctx_fork(ctx: CodegenCtx) -> CodegenCtx {
    bind fresh <- empty_ints();
    CodegenCtx { code: fresh  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }
}

fn ctx_merge(base: CodegenCtx, sub: CodegenCtx) -> CodegenCtx {
    bind next_local <- if base.next_local > sub.next_local {
        base.next_local
    } else {
        sub.next_local
    };
    CodegenCtx { code: base.code  consts: sub.consts  locals: base.locals  next_local: next_local  lifted: sub.lifted  next_lambda: sub.next_lambda  lambda_prefix: sub.lambda_prefix }
}

fn emit_byte(ctx: CodegenCtx, b: Int) -> CodegenCtx {
    CodegenCtx { code: List.push(ctx.code, b)  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }
}

fn emit_opcode(ctx: CodegenCtx, op: Bc) -> CodegenCtx {
    emit_byte(ctx, bc_byte(op))
}

fn u16_lo(n: Int) -> Int {
    Int.band(n, 255)
}

fn u16_hi(n: Int) -> Int {
    Int.band(Int.shr(n, 8), 255)
}

fn emit_u16(ctx: CodegenCtx, n: Int) -> CodegenCtx {
    bind ctx1 <- emit_byte(ctx, u16_lo(n));
    emit_byte(ctx1, u16_hi(n))
}

fn append_code(ctx: CodegenCtx, extra: List<Int>) -> CodegenCtx {
    CodegenCtx { code: List.concat(ctx.code, extra)  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }
}

fn code_op(op: Bc) -> List<Int> {
    List.singleton(bc_byte(op))
}

fn code_u16(n: Int) -> List<Int> {
    List.push(List.singleton(u16_lo(n)), u16_hi(n))
}

fn code_op_u16(op: Bc, n: Int) -> List<Int> {
    List.concat(code_op(op), code_u16(n))
}

fn add_const(ctx: CodegenCtx, cv: ConstVal) -> ConstAdd {
    bind idx <- List.length(ctx.consts);
    bind new_consts <- List.push(ctx.consts, cv);
    bind new_ctx <- CodegenCtx { code: ctx.code  consts: new_consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix };
    ConstAdd { ctx: new_ctx  idx: idx }
}

fn local_lookup(locals: List<KVPair>, name: String) -> Option<Int> {
    match List.first(locals) {
        None => Option.none()
        Some(kv) => {
            if kv.first == name {
                String.to_int(kv.second)
            } else {
                local_lookup(List.drop(locals, 1), name)
            }
        }
    }
}

fn local_add(ctx: CodegenCtx, name: String) -> CodegenCtx {
    bind idx_str <- Int.to_string(ctx.next_local);
    bind kv <- KVPair { first: name  second: idx_str };
    bind new_locals <- List.push(ctx.locals, kv);
    CodegenCtx { code: ctx.code  consts: ctx.consts  locals: new_locals  next_local: ctx.next_local + 1  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }
}

fn pattern_bind_locals(pat: Pat, ctx: CodegenCtx) -> CodegenCtx {
    match pat {
        PVar(name) => local_add(ctx, name)
        PVariantP(parts) => pattern_bind_locals(parts._1, ctx)
        _ => ctx
    }
}

fn set_lifted(ctx: CodegenCtx, lifted: List<FnEntry>, next_lambda: Int) -> CodegenCtx {
    CodegenCtx { code: ctx.code  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: lifted  next_lambda: next_lambda  lambda_prefix: ctx.lambda_prefix }
}

fn set_lambda_prefix(ctx: CodegenCtx, lambda_prefix: String) -> CodegenCtx {
    CodegenCtx { code: ctx.code  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: lambda_prefix }
}

fn local_name_by_slot(locals: List<KVPair>, slot: Int) -> Option<String> {
    match List.first(locals) {
        None => Option.none()
        Some(kv) => {
            match String.to_int(kv.second) {
                Some(idx) => {
                    if idx == slot {
                        Option.some(kv.first)
                    } else {
                        local_name_by_slot(List.drop(locals, 1), slot)
                    }
                }
                None => local_name_by_slot(List.drop(locals, 1), slot)
            }
        }
    }
}

fn empty_names() -> List<String> {
    List.drop_while(List.singleton(""), |v| true)
}

fn name_in_list(names: List<String>, target: String) -> Bool {
    match List.first(names) {
        None => false
        Some(name) => {
            if name == target {
                true
            } else {
                name_in_list(List.drop(names, 1), target)
            }
        }
    }
}

fn push_name_unique(names: List<String>, name: String) -> List<String> {
    if name_in_list(names, name) {
        names
    } else {
        List.push(names, name)
    }
}

fn pat_bound_names(pat: Pat, acc: List<String>) -> List<String> {
    match pat {
        PVar(name) => List.push(acc, name)
        PVariantP(parts) => pat_bound_names(parts._1, acc)
        _ => acc
    }
}

fn free_names_arms(arms: Expr, bound: List<String>, acc: List<String>) -> List<String> {
    match arms {
        EArm(parts) => {
            bind pat <- parts._0;
            bind guard <- parts._1;
            bind body <- parts._2;
            bind rest <- parts._3;
            bind arm_bound <- pat_bound_names(pat, bound);
            bind acc1 <- free_names_expr(guard, arm_bound, acc);
            bind acc2 <- free_names_expr(body, arm_bound, acc1);
            free_names_arms(rest, bound, acc2)
        }
        EArmNil => acc
        _ => acc
    }
}

fn free_names_expr(expr: Expr, bound: List<String>, acc: List<String>) -> List<String> {
    match expr {
        ELit(_) => acc
        EVar(name) => {
            if name_in_list(bound, name) {
                acc
            } else {
                List.push(acc, name)
            }
        }
        EBinOp(parts) => {
            bind left <- parts._1;
            bind right <- parts._2;
            bind acc1 <- free_names_expr(left, bound, acc);
            free_names_expr(right, bound, acc1)
        }
        ECall(parts) => free_names_expr(parts._2, bound, acc)
        EIf(parts) => {
            bind cond <- parts._0;
            bind then_e <- parts._1;
            bind else_e <- parts._2;
            bind acc1 <- free_names_expr(cond, bound, acc);
            bind acc2 <- free_names_expr(then_e, bound, acc1);
            free_names_expr(else_e, bound, acc2)
        }
        EAccess(parts) => free_names_expr(parts._0, bound, acc)
        ELambda(parts) => {
            bind param <- parts._0;
            bind body <- parts._1;
            bind inner_bound <- List.push(bound, param);
            free_names_expr(body, inner_bound, acc)
        }
        EMatch(parts) => {
            bind scrut <- parts._0;
            bind arms <- parts._1;
            bind acc1 <- free_names_expr(scrut, bound, acc);
            free_names_arms(arms, bound, acc1)
        }
        EBlock(parts) => {
            bind head <- parts._0;
            bind tail <- parts._1;
            bind acc1 <- free_names_expr(head, bound, acc);
            free_names_expr(tail, bound, acc1)
        }
        ERecordLit(parts) => free_names_expr(parts._1, bound, acc)
        EArgList(parts) => {
            bind head <- parts._0;
            bind tail <- parts._1;
            bind acc1 <- free_names_expr(head, bound, acc);
            free_names_expr(tail, bound, acc1)
        }
        EArgNil => acc
        EArm(_parts) => acc
        EArmNil => acc
        EBind({ _0: name, _1: val_e, _2: cont_e }) => {
            bind acc1 <- free_names_expr(val_e, bound, acc);
            bind cont_bound <- List.push(bound, name);
            free_names_expr(cont_e, cont_bound, acc1)
        }
        ECollect(body) => free_names_expr(body, bound, acc)
        EYield(val_e) => free_names_expr(val_e, bound, acc)
        EField(parts) => {
            bind val_e <- parts._1;
            bind rest <- parts._2;
            bind acc1 <- free_names_expr(val_e, bound, acc);
            free_names_expr(rest, bound, acc1)
        }
        EFieldNil => acc
        EQuestion(inner) => free_names_expr(inner, bound, acc)
    }
}

fn collect_capture_names(locals: List<KVPair>, slot: Int, max: Int, acc: List<String>) -> List<String> {
    if slot >= max {
        acc
    } else {
        match local_name_by_slot(locals, slot) {
            Some(name) => collect_capture_names(locals, slot + 1, max, List.push(acc, name))
            None => collect_capture_names(locals, slot + 1, max, acc)
        }
    }
}

fn capture_names(ctx: CodegenCtx) -> List<String> {
    bind acc <- empty_names();
    collect_capture_names(ctx.locals, 0, ctx.next_local, acc)
}

fn collect_used_capture_names(used: List<String>, locals: List<KVPair>, acc: List<String>) -> List<String> {
    match List.first(used) {
        None => acc
        Some(name) => {
            match local_lookup(locals, name) {
                Some(_idx) => {
                    if name_in_list(acc, name) {
                        collect_used_capture_names(List.drop(used, 1), locals, acc)
                    } else {
                        collect_used_capture_names(List.drop(used, 1), locals, List.push(acc, name))
                    }
                }
                None => collect_used_capture_names(List.drop(used, 1), locals, acc)
            }
        }
    }
}

fn capture_names_for_lambda(param: String, body: Expr, ctx: CodegenCtx) -> List<String> {
    bind seed <- empty_names();
    bind bound <- List.singleton(param);
    bind used <- free_names_expr(body, bound, seed);
    bind acc <- empty_names();
    collect_used_capture_names(used, ctx.locals, acc)
}

fn load_captures(names: List<String>, ctx: CodegenCtx) -> Result<CodegenCtx, String> {
    match List.first(names) {
        None => Result.ok(ctx)
        Some(name) => {
            match local_lookup(ctx.locals, name) {
                None => Result.err(String.concat("missing capture local: ", name))
                Some(slot) => {
                    bind ctx1 <- emit_opcode(ctx, BcLoadLocal);
                    bind ctx2 <- emit_u16(ctx1, slot);
                    load_captures(List.drop(names, 1), ctx2)
                }
            }
        }
    }
}

fn locals_from_names(names: List<String>, ctx: CodegenCtx) -> CodegenCtx {
    match List.first(names) {
        None => ctx
        Some(name) => {
            bind ctx1 <- local_add(ctx, name);
            locals_from_names(List.drop(names, 1), ctx1)
        }
    }
}

fn new_lambda_name(ctx: CodegenCtx) -> LambdaNameResult {
    LambdaNameResult { name: String.concat(String.concat(ctx.lambda_prefix, "__lambda_"), Int.to_string(ctx.next_lambda))  next_lambda: ctx.next_lambda + 1 }
}

fn result_err_expr(err_name: String) -> Expr {
    ECall("Result", "err", EArgList(EVar(err_name), EArgNil))
}

fn result_and_then_match_expr(value_expr: Expr, param: String, body: Expr) -> Expr {
    bind err_name <- "__result_and_then_err";
    EMatch(value_expr, EArm(PVariantP("Ok", PVar(param)), ELit(LBool(true)), body, EArm(PVariantP("Err", PVar(err_name)), ELit(LBool(true)), result_err_expr(err_name), EArmNil)))
}

fn compile_result_and_then_expr(args: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    match args {
        EArgList({ _0: head, _1: tail }) => {
            match head {
                ELambda({ _0: param, _1: body }) => {
                    match tail {
                        EArgList({ _0: value_expr, _1: EArgNil }) => compile_expr(result_and_then_match_expr(value_expr, param, body), ctx, env)
                        _ => Result.err("internal: Result.and_then expects two arguments")
                    }
                }
                _ => {
                    match tail {
                        EArgList({ _0: ELambda({ _0: param, _1: body }), _1: EArgNil }) => compile_expr(result_and_then_match_expr(head, param, body), ctx, env)
                        _ => Result.err("internal: Result.and_then expects value and lambda")
                    }
                }
            }
        }
        _ => Result.err("internal: Result.and_then expects argument list")
    }
}

fn compile_lit(lit: Lit, ctx: CodegenCtx) -> CodegenCtx {
    match lit {
        LBool(b) => {
            if b {
                emit_opcode(ctx, BcConstTrue)
            } else {
                emit_opcode(ctx, BcConstFalse)
            }
        }
        LUnit => emit_opcode(ctx, BcConstUnit)
        LInt(n) => {
            bind ca <- add_const(ctx, CVInt(n));
            bind ctx1 <- emit_opcode(ca.ctx, BcConst);
            emit_u16(ctx1, ca.idx)
        }
        LFloat(f) => {
            bind ca <- add_const(ctx, CVFloat(f));
            bind ctx1 <- emit_opcode(ca.ctx, BcConst);
            emit_u16(ctx1, ca.idx)
        }
        LStr(s) => {
            bind ca <- add_const(ctx, CVStr(s));
            bind ctx1 <- emit_opcode(ca.ctx, BcConst);
            emit_u16(ctx1, ca.idx)
        }
    }
}

fn binop_bc(op: Op) -> Bc {
    match op {
        OpAdd => BcAdd
        OpSub => BcSub
        OpMul => BcMul
        OpDiv => BcDiv
        OpMod => BcDiv
        OpEq => BcEq
        OpNeq => BcNe
        OpLt => BcLt
        OpGt => BcGt
        OpLtEq => BcLe
        OpGtEq => BcGe
        OpAnd => BcAnd
        OpOr => BcOr
        // unreachable: OpNullCoalesce は compile_expr で EMatch desugar される
        OpNullCoalesce => BcOr
    }
}

fn count_args(args: Expr) -> Int {
    match args {
        EArgNil => 0
        EArgList(parts) => count_args(parts._1) + 1
        EFieldNil => 0
        EField(parts) => count_args(parts._2) + 1
        _ => 0
    }
}

fn reverse_match_arms_loop(arms: Expr, acc: Expr) -> Expr {
    match arms {
        EArm(parts) => reverse_match_arms_loop(parts._3, EArm(parts._0, parts._1, parts._2, acc))
        EArmNil => acc
        _ => acc
    }
}

fn reverse_match_arms(arms: Expr) -> Expr {
    reverse_match_arms_loop(arms, EArmNil)
}

fn compile_if_assemble(ctx_c: CodegenCtx, ctx_t: CodegenCtx, ctx_e: CodegenCtx) -> Result<CodegenCtx, String> {
    bind then_len <- List.length(ctx_t.code);
    bind else_len <- List.length(ctx_e.code);
    bind base <- ctx_merge(ctx_c, ctx_e);
    bind ctx1 <- emit_opcode(base, BcJumpIfFalse);
    bind ctx2 <- emit_u16(ctx1, then_len + 3);
    bind ctx3 <- append_code(ctx2, ctx_t.code);
    bind ctx4 <- emit_opcode(ctx3, BcJump);
    bind ctx5 <- emit_u16(ctx4, else_len);
    Result.ok(append_code(ctx5, ctx_e.code))
}

fn compile_if_then_done(ctx_c: CodegenCtx, ctx_t: CodegenCtx, else_e: Expr, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind sub_else <- ctx_fork(ctx_merge(ctx_c, ctx_t));
    Result.and_then(compile_expr(else_e, sub_else, env), |ctx_e| compile_if_assemble(ctx_c, ctx_t, ctx_e))
}

fn compile_if_cond_done(ctx_c: CodegenCtx, then_e: Expr, else_e: Expr, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind sub_then <- ctx_fork(ctx_c);
    Result.and_then(compile_expr(then_e, sub_then, env), |ctx_t| compile_if_then_done(ctx_c, ctx_t, else_e, env))
}

fn compile_if(cond: Expr, then_e: Expr, else_e: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    Result.and_then(compile_expr(cond, ctx, env), |ctx_c| compile_if_cond_done(ctx_c, then_e, else_e, env))
}

fn compile_call_cont(full_name: String, argc: Int, ctx1: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ca <- add_const(ctx1, CVName(full_name));
    bind ctx2 <- emit_opcode(ca.ctx, BcCallNamed);
    bind ctx3 <- emit_u16(ctx2, ca.idx);
    Result.ok(emit_u16(ctx3, argc))
}

fn compile_value_call_cont(slot: Int, argc: Int, ctx1: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ctx2 <- emit_opcode(ctx1, BcCall);
    Result.ok(emit_u16(ctx2, argc))
}

fn compile_access_cont(field: String, ctx1: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ca <- add_const(ctx1, CVName(field));
    bind ctx2 <- emit_opcode(ca.ctx, BcGetField);
    Result.ok(emit_u16(ctx2, ca.idx))
}

fn compile_record_cont(base_idx: Int, n: Int, ctx1: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ctx2 <- emit_opcode(ctx1, BcBuildRecord);
    bind ctx3 <- emit_u16(ctx2, n);
    Result.ok(emit_u16(ctx3, base_idx))
}

fn add_field_name_consts(fields: Expr, ctx: CodegenCtx) -> ConstAdd {
    bind base_idx <- List.length(ctx.consts);
    bind final_ctx <- add_field_name_consts_loop(fields, ctx);
    ConstAdd { ctx: final_ctx  idx: base_idx }
}

fn add_field_name_consts_loop(fields: Expr, ctx: CodegenCtx) -> CodegenCtx {
    match fields {
        EField(parts) => {
            bind fname <- parts._0;
            bind rest <- parts._2;
            bind ctx1 <- add_field_name_consts_loop(rest, ctx);
            bind ca <- add_const(ctx1, CVName(fname));
            ca.ctx
        }
        EFieldNil => ctx
        _ => ctx
    }
}

fn compile_record_fields(fields: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    match fields {
        EField(parts) => {
            bind val_e <- parts._1;
            bind rest <- parts._2;
            Result.and_then(compile_record_fields(rest, ctx, env), |ctx1| compile_expr(val_e, ctx1, env))
        }
        EFieldNil => Result.ok(ctx)
        _ => Result.err("expected record field list")
    }
}

fn compile_record_after_fields(fields: Expr, n: Int, ctx1: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ca <- add_field_name_consts(fields, ctx1);
    compile_record_cont(ca.idx, n, ca.ctx)
}

fn compile_pattern_lit(lit: Lit, ctx: CodegenCtx, success_code: List<Int>, fail_code: List<Int>) -> Result<PatDispatch, String> {
    bind ctx1 <- emit_opcode(ctx, BcDup);
    bind ctx2 <- compile_lit(lit, ctx1);
    bind ctx3 <- emit_opcode(ctx2, BcEq);
    bind false_off <- List.length(success_code) + 3;
    bind ctx4 <- emit_opcode(ctx3, BcJumpIfFalse);
    bind ctx5 <- emit_u16(ctx4, false_off);
    bind ctx6 <- append_code(ctx5, success_code);
    bind ctx7 <- emit_opcode(ctx6, BcJump);
    bind ctx8 <- emit_u16(ctx7, List.length(fail_code));
    bind code <- List.concat(ctx8.code, fail_code);
    bind fail_offset <- List.length(code) - List.length(fail_code);
    Result.ok(PatDispatch { ctx: CodegenCtx { code: code  consts: ctx8.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx8.lifted  next_lambda: ctx8.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: fail_offset })
}

fn normalize_variant_tag(name: String) -> String {
    if name == "Ok" {
        "ok"
    } else {
        if name == "Err" {
            "err"
        } else {
            if name == "Some" {
                "some"
            } else {
                if name == "None" {
                    "none"
                } else {
                    name
                }
            }
        }
    }
}

fn compile_pattern_dispatch(pat: Pat, ctx: CodegenCtx, success_code: List<Int>, fail_code: List<Int>) -> Result<PatDispatch, String> {
    match pat {
        PWild => {
            Result.ok(PatDispatch { ctx: CodegenCtx { code: success_code  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: List.length(success_code) })
        }
        PVar(name) => {
            match local_lookup(ctx.locals, name) {
                None => Result.err(String.concat("unknown pattern local: ", name))
                Some(slot) => {
                    bind code <- List.concat(code_op(BcDup), List.concat(code_op_u16(BcStoreLocal, slot), success_code));
                    Result.ok(PatDispatch { ctx: CodegenCtx { code: code  consts: ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx.lifted  next_lambda: ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: List.length(code) })
                }
            }
        }
        PInt(n) => compile_pattern_lit(LInt(n), ctx, success_code, fail_code)
        PFloat(f) => compile_pattern_lit(LFloat(f), ctx, success_code, fail_code)
        PStr(s) => compile_pattern_lit(LStr(s), ctx, success_code, fail_code)
        PBool(b) => compile_pattern_lit(LBool(b), ctx, success_code, fail_code)
        PUnit => compile_pattern_lit(LUnit, ctx, success_code, fail_code)
        PVariant(name) => {
            bind ca <- add_const(ctx, CVName(normalize_variant_tag(name)));
            bind ctx1 <- emit_opcode(ca.ctx, BcDup);
            bind success_path <- List.concat(code_op(BcPop), success_code);
            bind fail_path <- List.concat(code_op(BcPop), fail_code);
            bind jump_len <- List.length(success_path) + 3;
            bind ctx2 <- emit_opcode(ctx1, BcJumpIfNotVariantC);
            bind ctx3 <- emit_u16(ctx2, ca.idx);
            bind ctx4 <- emit_u16(ctx3, jump_len);
            bind ctx5 <- append_code(ctx4, success_path);
            bind ctx6 <- emit_opcode(ctx5, BcJump);
            bind ctx7 <- emit_u16(ctx6, List.length(fail_path));
            bind code <- List.concat(ctx7.code, fail_path);
            bind fail_offset <- List.length(code) - List.length(fail_path);
            Result.ok(PatDispatch { ctx: CodegenCtx { code: code  consts: ctx7.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx7.lifted  next_lambda: ctx7.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: fail_offset })
        }
        PVariantP(parts) => {
            bind name <- parts._0;
            bind inner <- parts._1;
            match inner {
                PWild => {
                    compile_pattern_dispatch(PVariant(name), ctx, success_code, fail_code)
                }
                PVar(inner_name) => {
                    match local_lookup(ctx.locals, inner_name) {
                        None => Result.err(String.concat("unknown pattern local: ", inner_name))
                        Some(slot) => {
                            bind ca <- add_const(ctx, CVName(normalize_variant_tag(name)));
                            bind success_path <- List.concat(code_op(BcGetVariantPayload), List.concat(code_op(BcDup), List.concat(code_op_u16(BcStoreLocal, slot), List.concat(code_op(BcPop), success_code))));
                            bind fail_path <- List.concat(code_op(BcPop), fail_code);
                            bind ctx1 <- emit_opcode(ca.ctx, BcDup);
                            bind ctx2 <- emit_opcode(ctx1, BcJumpIfNotVariantC);
                            bind ctx3 <- emit_u16(ctx2, ca.idx);
                            bind ctx4 <- emit_u16(ctx3, List.length(success_path) + 3);
                            bind ctx5 <- append_code(ctx4, success_path);
                            bind ctx6 <- emit_opcode(ctx5, BcJump);
                            bind ctx7 <- emit_u16(ctx6, List.length(fail_path));
                            bind code <- List.concat(ctx7.code, fail_path);
                            bind fail_offset <- List.length(code) - List.length(fail_path);
                            Result.ok(PatDispatch { ctx: CodegenCtx { code: code  consts: ctx7.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx7.lifted  next_lambda: ctx7.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: fail_offset })
                        }
                    }
                }
                _ => {
                    bind inner_success <- List.concat(code_op(BcPop), success_code);
                    bind outer_fail_path <- List.concat(code_op(BcPop), fail_code);
                    Result.and_then(compile_pattern_dispatch(inner, ctx_fork(ctx), inner_success, outer_fail_path), |inner_pd| {
                        bind inner_fail_path <- List.drop(inner_pd.ctx.code, inner_pd.fail_offset);
                        bind ca <- add_const(CodegenCtx { code: empty_ints()  consts: inner_pd.ctx.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: inner_pd.ctx.lifted  next_lambda: inner_pd.ctx.next_lambda  lambda_prefix: ctx.lambda_prefix }, CVName(normalize_variant_tag(name)));
                        bind ctx1 <- emit_opcode(ca.ctx, BcDup);
                        bind ctx2 <- emit_opcode(ctx1, BcJumpIfNotVariantC);
                        bind ctx3 <- emit_u16(ctx2, ca.idx);
                        bind success_path <- List.concat(code_op(BcGetVariantPayload), inner_pd.ctx.code);
                        bind jump_len <- inner_pd.fail_offset + 1;
                        bind ctx4 <- emit_u16(ctx3, jump_len);
                        bind code <- List.concat(ctx4.code, success_path);
                        bind fail_offset <- List.length(code) - List.length(inner_fail_path);
                        Result.ok(PatDispatch { ctx: CodegenCtx { code: code  consts: ctx4.consts  locals: ctx.locals  next_local: ctx.next_local  lifted: ctx4.lifted  next_lambda: ctx4.next_lambda  lambda_prefix: ctx.lambda_prefix }  fail_offset: fail_offset })
                    })
                }
            }
        }
    }
}

fn compile_match_body_finish(body_ctx: CodegenCtx) -> CodegenCtx {
    bind body1 <- emit_opcode(body_ctx, BcSwap);
    emit_opcode(body1, BcPop)
}

fn compile_match_guard_assemble(guard_ctx: CodegenCtx, body_ctx: CodegenCtx, fail_code: List<Int>) -> CodegenCtx {
    bind body_len <- List.length(body_ctx.code);
    bind fail_len <- List.length(fail_code);
    bind ctx1 <- emit_opcode(guard_ctx, BcJumpIfFalse);
    bind ctx2 <- emit_u16(ctx1, body_len + 3);
    bind ctx3 <- append_code(ctx2, body_ctx.code);
    bind ctx4 <- emit_opcode(ctx3, BcJump);
    bind ctx5 <- emit_u16(ctx4, fail_len);
    append_code(ctx5, fail_code)
}

fn compile_match_dispatch_finish(pat: Pat, body2: CodegenCtx, bound_ctx: CodegenCtx, ctx: CodegenCtx, fail_code: List<Int>) -> Result<CodegenCtx, String> {
    bind next_local <- if body2.next_local > bound_ctx.next_local {
        body2.next_local
    } else {
        bound_ctx.next_local
    };
    bind next_local2 <- if next_local > ctx.next_local {
        next_local
    } else {
        ctx.next_local
    };
    Result.and_then(compile_pattern_dispatch(pat, CodegenCtx { code: empty_ints()  consts: body2.consts  locals: bound_ctx.locals  next_local: bound_ctx.next_local  lifted: body2.lifted  next_lambda: body2.next_lambda  lambda_prefix: body2.lambda_prefix }, body2.code, fail_code), |pat_pd| Result.ok(CodegenCtx { code: pat_pd.ctx.code  consts: pat_pd.ctx.consts  locals: ctx.locals  next_local: next_local2  lifted: pat_pd.ctx.lifted  next_lambda: pat_pd.ctx.next_lambda  lambda_prefix: pat_pd.ctx.lambda_prefix }))
}

fn compile_match_body_result(pat: Pat, body_ctx: CodegenCtx, bound_ctx: CodegenCtx, ctx: CodegenCtx, fail_code: List<Int>) -> Result<CodegenCtx, String> {
    bind body2 <- compile_match_body_finish(body_ctx);
    compile_match_dispatch_finish(pat, body2, bound_ctx, ctx, fail_code)
}

fn compile_match_guard_result(pat: Pat, guard: Expr, body_ctx: CodegenCtx, bound_ctx: CodegenCtx, ctx: CodegenCtx, fail_code: List<Int>, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind body2 <- compile_match_body_finish(body_ctx);
    Result.and_then(compile_expr(guard, CodegenCtx { code: empty_ints()  consts: body2.consts  locals: bound_ctx.locals  next_local: bound_ctx.next_local  lifted: body2.lifted  next_lambda: body2.next_lambda  lambda_prefix: body2.lambda_prefix }, env), |guard_ctx| {
        bind next_local <- if body2.next_local > guard_ctx.next_local {
            body2.next_local
        } else {
            guard_ctx.next_local
        };
        bind guard_body <- compile_match_guard_assemble(guard_ctx, CodegenCtx { code: body2.code  consts: guard_ctx.consts  locals: body2.locals  next_local: next_local  lifted: guard_ctx.lifted  next_lambda: guard_ctx.next_lambda  lambda_prefix: guard_ctx.lambda_prefix }, fail_code);
        compile_match_dispatch_finish(pat, guard_body, bound_ctx, ctx, fail_code)
    })
}

fn compile_match_arm(pat: Pat, guard: Expr, body: Expr, fail_code: List<Int>, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind bound_ctx <- pattern_bind_locals(pat, ctx);
    bind body_seed <- ctx_fork(bound_ctx);
    Result.and_then(compile_expr(body, body_seed, env), |body_ctx| match guard {
        ELit(LBool(true)) => compile_match_body_result(pat, body_ctx, bound_ctx, ctx, fail_code)
        _ => compile_match_guard_result(pat, guard, body_ctx, bound_ctx, ctx, fail_code, env)
    })
}

fn compile_match_arms(arms: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    match arms {
        EArm(parts) => {
            bind pat <- parts._0;
            bind guard <- parts._1;
            bind body <- parts._2;
            bind rest <- parts._3;
            bind fail_seed <- ctx_fork(ctx);
            Result.and_then(compile_match_arms(rest, fail_seed, env), |fail_ctx| compile_match_arm(pat, guard, body, fail_ctx.code, CodegenCtx { code: empty_ints()  consts: fail_ctx.consts  locals: ctx.locals  next_local: fail_ctx.next_local  lifted: fail_ctx.lifted  next_lambda: fail_ctx.next_lambda  lambda_prefix: fail_ctx.lambda_prefix }, env))
        }
        EArmNil => Result.ok(emit_opcode(ctx, BcMatchFail))
        _ => Result.err("expected match arms")
    }
}

fn compile_bind_cont(name: String, cont_e: Expr, ctx1: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind idx <- ctx1.next_local;
    bind ctx2 <- local_add(ctx1, name);
    bind ctx3 <- emit_opcode(ctx2, BcStoreLocal);
    bind ctx4 <- emit_u16(ctx3, idx);
    compile_expr(cont_e, ctx4, env)
}

fn lambda_fn_entry(name: String, arity: Int, body_ctx: CodegenCtx) -> FnEntry {
    FnEntry { fname: name  arity: arity  local_count: body_ctx.next_local  code: body_ctx.code  consts: body_ctx.consts  ret_ty: ""  is_public: false }
}

fn append_fn_entries(left: List<FnEntry>, right: List<FnEntry>) -> List<FnEntry> {
    List.concat(left, right)
}

fn compile_lambda_after_captures(ctx_caps: CodegenCtx, captures: List<String>, lambda_name: String, body_ctx: CodegenCtx) -> Result<CodegenCtx, String> {
    bind ca <- add_const(ctx_caps, CVName(lambda_name));
    bind ctx1 <- emit_opcode(ca.ctx, BcMakeClosureN);
    bind ctx2 <- emit_u16(ctx1, ca.idx);
    bind ctx3 <- emit_u16(ctx2, List.length(captures));
    bind lifted1 <- List.push(ctx3.lifted, lambda_fn_entry(lambda_name, List.length(captures) + 1, body_ctx));
    Result.ok(set_lifted(ctx3, lifted1, ctx3.next_lambda))
}

fn compile_lambda_cont(outer_ctx: CodegenCtx, captures: List<String>, lambda_name: String, body_ctx: CodegenCtx) -> Result<CodegenCtx, String> {
    bind outer1 <- set_lifted(outer_ctx, append_fn_entries(outer_ctx.lifted, body_ctx.lifted), body_ctx.next_lambda);
    Result.and_then(load_captures(captures, outer1), |ctx_caps| compile_lambda_after_captures(ctx_caps, captures, lambda_name, body_ctx))
}

fn compile_lambda_body_result(body_ctx0: CodegenCtx, ctx: CodegenCtx, captures: List<String>, lambda_name: String, next_lambda: Int) -> Result<CodegenCtx, String> {
    bind body_ret <- emit_opcode(body_ctx0, BcReturn);
    bind body_ctx <- set_lifted(body_ret, body_ret.lifted, body_ret.next_lambda);
    bind outer_seed <- set_lifted(ctx, ctx.lifted, next_lambda);
    compile_lambda_cont(outer_seed, captures, lambda_name, body_ctx)
}

fn compile_lambda_expr(param: String, body: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    bind captures <- capture_names_for_lambda(param, body, ctx);
    bind name_pair <- new_lambda_name(ctx);
    bind lambda_name <- name_pair.name;
    bind next_lambda <- name_pair.next_lambda;
    bind lambda_seed0 <- new_ctx();
    bind lambda_seed1a <- set_lambda_prefix(lambda_seed0, ctx.lambda_prefix);
    bind lambda_seed1 <- set_lifted(lambda_seed1a, empty_fns(), next_lambda);
    bind lambda_seed2 <- locals_from_names(captures, lambda_seed1);
    bind lambda_seed3 <- local_add(lambda_seed2, param);
    Result.and_then(compile_expr(body, lambda_seed3, env), |body_ctx0| compile_lambda_body_result(body_ctx0, ctx, captures, lambda_name, next_lambda))
}

fn compile_args(args: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    match args {
        EArgNil => Result.ok(ctx)
        EArgList(parts) => {
            bind head <- parts._0;
            bind tail <- parts._1;
            Result.and_then(compile_args(tail, ctx, env), |ctx1| compile_expr(head, ctx1, env))
        }
        EFieldNil => Result.ok(ctx)
        EField(parts) => {
            bind val_e <- parts._1;
            bind tail <- parts._2;
            Result.and_then(compile_args(tail, ctx, env), |ctx1| compile_expr(val_e, ctx1, env))
        }
        _ => Result.err("expected argument list")
    }
}

fn compile_expr(expr: Expr, ctx: CodegenCtx, env: List<KVPair>) -> Result<CodegenCtx, String> {
    match expr {
        ELit(lit) => Result.ok(compile_lit(lit, ctx))
        EVar(name) => {
            match local_lookup(ctx.locals, name) {
                Some(idx) => {
                    bind ctx1 <- emit_opcode(ctx, BcLoadLocal);
                    Result.ok(emit_u16(ctx1, idx))
                }
                None => {
                    bind ca <- add_const(ctx, CVName(name));
                    bind ctx1 <- emit_opcode(ca.ctx, BcLoadGlobal);
                    Result.ok(emit_u16(ctx1, ca.idx))
                }
            }
        }
        EBinOp(parts) => {
            bind op <- parts._0;
            bind left <- parts._1;
            bind right <- parts._2;
            match op {
                OpNullCoalesce => compile_expr(EMatch(left, EArm(PVariantP("Some", PVar("__nc_v")), ELit(LBool(true)), EVar("__nc_v"), EArm(PVariant("None"), ELit(LBool(true)), right, EArmNil))), ctx, env)
                _ => Result.and_then(compile_expr(left, ctx, env), |ctx1| Result.and_then(compile_expr(right, ctx1, env), |ctx2| Result.ok(emit_opcode(ctx2, binop_bc(op)))))
            }
        }
        EIf(parts) => compile_if(parts._0, parts._1, parts._2, ctx, env)
        EBind(parts) => {
            bind name <- parts._0;
            bind val_e <- parts._1;
            bind cont_e <- parts._2;
            Result.and_then(compile_expr(val_e, ctx, env), |ctx1| compile_bind_cont(name, cont_e, ctx1, env))
        }
        ECollect(body) => {
            bind ctx1 <- emit_opcode(ctx, BcCollectBegin);
            Result.and_then(compile_expr(body, ctx1, env), |ctx2| Result.ok(emit_opcode(ctx2, BcCollectEnd)))
        }
        EYield(val_e) => {
            Result.and_then(compile_expr(val_e, ctx, env), |ctx1| Result.ok(emit_opcode(ctx1, BcYieldValue)))
        }
        ECall(parts) => {
            bind ns <- parts._0;
            bind fname <- parts._1;
            bind args <- parts._2;
            if (ns == "Result") && (fname == "and_then") {
                compile_result_and_then_expr(args, ctx, env)
            } else {
                bind argc <- count_args(args);
                if ns == "" {
                    match local_lookup(ctx.locals, fname) {
                        Some(slot) => {
                            Result.and_then(compile_expr(EVar(fname), ctx, env), |ctx1| Result.and_then(compile_args(args, ctx1, env), |ctx2| compile_value_call_cont(slot, argc, ctx2)))
                        }
                        None => {
                            Result.and_then(compile_args(args, ctx, env), |ctx1| compile_call_cont(fname, argc, ctx1))
                        }
                    }
                } else {
                    bind full_name <- String.concat(ns, String.concat(".", fname));
                    Result.and_then(compile_args(args, ctx, env), |ctx1| compile_call_cont(full_name, argc, ctx1))
                }
            }
        }
        EAccess(parts) => {
            bind obj <- parts._0;
            bind field <- parts._1;
            Result.and_then(compile_expr(obj, ctx, env), |ctx1| compile_access_cont(field, ctx1))
        }
        EBlock(parts) => {
            bind head <- parts._0;
            bind tail <- parts._1;
            Result.and_then(compile_expr(head, ctx, env), |ctx1| compile_expr(tail, ctx1, env))
        }
        EMatch(parts) => {
            bind scrut <- parts._0;
            bind arms <- parts._1;
            Result.and_then(compile_expr(scrut, ctx, env), |ctx1| Result.and_then(compile_match_arms(arms, CodegenCtx { code: empty_ints()  consts: ctx1.consts  locals: ctx1.locals  next_local: ctx1.next_local  lifted: ctx1.lifted  next_lambda: ctx1.next_lambda  lambda_prefix: ctx1.lambda_prefix }, env), |arms_ctx| Result.ok(CodegenCtx { code: List.concat(ctx1.code, arms_ctx.code)  consts: arms_ctx.consts  locals: ctx1.locals  next_local: arms_ctx.next_local  lifted: arms_ctx.lifted  next_lambda: arms_ctx.next_lambda  lambda_prefix: arms_ctx.lambda_prefix })))
        }
        ELambda(parts) => {
            compile_lambda_expr(parts._0, parts._1, ctx, env)
        }
        ERecordLit(parts) => {
            bind fields <- parts._1;
            bind n <- count_args(fields);
            Result.and_then(compile_record_fields(fields, ctx, env), |ctx1| compile_record_after_fields(fields, n, ctx1))
        }
        EArgList(parts) => {
            bind head <- parts._0;
            bind tail <- parts._1;
            Result.and_then(compile_expr(head, ctx, env), |ctx1| compile_expr(tail, ctx1, env))
        }
        EArgNil => Result.ok(ctx)
        EArm(parts) => compile_expr(parts._3, ctx, env)
        EArmNil => Result.ok(ctx)
        EField(parts) => {
            bind val_e <- parts._1;
            bind rest <- parts._2;
            Result.and_then(compile_expr(val_e, ctx, env), |ctx1| compile_expr(rest, ctx1, env))
        }
        EFieldNil => Result.ok(ctx)
        EQuestion(inner) => compile_expr(result_and_then_match_expr(inner, "__q_val", EVar("__q_val")), ctx, env)
    }
}

fn compile_params(params: List<Param>, ctx: CodegenCtx) -> CodegenCtx {
    match List.first(params) {
        None => ctx
        Some(p) => {
            bind ctx1 <- local_add(ctx, p.name);
            compile_params(List.drop(params, 1), ctx1)
        }
    }
}

fn empty_env() -> List<KVPair> {
    List.drop_while(List.singleton(KVPair { first: ""  second: "" }), |v| true)
}

fn type_expr_to_str(ty: TypeExpr) -> String {
    match ty {
        TeSimple(name) => name
        TeList(inner) => String.concat("List<", String.concat(type_expr_to_str(inner), ">"))
        TeOption(inner) => String.concat("Option<", String.concat(type_expr_to_str(inner), ">"))
        TeResult({ _0: ok_t, _1: err_t }) => String.concat("Result<", String.concat(type_expr_to_str(ok_t), String.concat(", ", String.concat(type_expr_to_str(err_t), ">"))))
        TeMap({ _0: k_t, _1: v_t }) => String.concat("Map<", String.concat(type_expr_to_str(k_t), String.concat(", ", String.concat(type_expr_to_str(v_t), ">"))))
        TeFn({ _0: from_t, _1: to_t }) => String.concat("Fn<", String.concat(type_expr_to_str(from_t), String.concat(" -> ", String.concat(type_expr_to_str(to_t), ">"))))
    }
}

fn make_fn_entry(fn_def: FnDef, ctx_ret: CodegenCtx, arity: Int, ret_ty: String) -> FnEntry {
    FnEntry { fname: fn_def.name  arity: arity  local_count: ctx_ret.next_local  code: ctx_ret.code  consts: ctx_ret.consts  ret_ty: ret_ty  is_public: fn_def.is_public }
}

fn finish_fn_def(fn_def: FnDef, ctx_done: CodegenCtx, arity: Int, ret_ty: String) -> Result<List<FnEntry>, String> {
    bind ctx_ret <- emit_opcode(ctx_done, BcReturn);
    bind entries <- List.push(ctx_ret.lifted, make_fn_entry(fn_def, ctx_ret, arity, ret_ty));
    Result.ok(entries)
}

fn compile_fn_def(fn_def: FnDef) -> Result<List<FnEntry>, String> {
    bind ctx0a <- new_ctx();
    bind ctx0 <- set_lambda_prefix(ctx0a, String.concat(fn_def.name, "$"));
    bind ctx1 <- compile_params(fn_def.params, ctx0);
    bind env0 <- empty_env();
    bind arity <- List.length(fn_def.params);
    bind ret_ty <- type_expr_to_str(fn_def.ret);
    Result.and_then(compile_expr(fn_def.body, ctx1, env0), |ctx_done| finish_fn_def(fn_def, ctx_done, arity, ret_ty))
}

fn empty_fns() -> List<FnEntry> {
    List.drop_while(List.singleton(FnEntry { fname: ""  arity: 0  local_count: 0  code: empty_ints()  consts: empty_consts()  ret_ty: ""  is_public: false }), |v| true)
}

fn compile_stage_body(stage_def: StageDef, body: Expr) -> Result<List<FnEntry>, String> {
    match body {
        ELambda({ _0: pname, _1: inner }) => {
            bind fn_def <- FnDef { is_public: stage_def.is_public  name: stage_def.name  params: List.singleton(Param { name: pname  ty: stage_def.param_ty })  ret: stage_def.ret_ty  body: inner  doc: "" };
            compile_fn_def(fn_def)
        }
        _ => Result.err(String.concat("stage body must be a lambda: ", stage_def.name))
    }
}

fn compile_stage_def(stage_def: StageDef) -> Result<List<FnEntry>, String> {
    match stage_def.body {
        None => {
            bind empty <- empty_fns();
            Result.ok(empty)
        }
        Some(body) => compile_stage_body(stage_def, body)
    }
}

fn build_par_names_expr_acc(names: List<String>, acc: Expr) -> Expr {
    match List.first(names) {
        None => acc
        Some(n) => {
            bind rest <- List.drop(names, 1);
            bind new_acc <- ECall("List", "push", EArgList(acc, EArgList(ELit(LStr(n)), EArgNil)));
            build_par_names_expr_acc(rest, new_acc)
        }
    }
}

fn build_par_names_expr(names: List<String>) -> Expr {
    build_par_names_expr_acc(names, ECall("List", "empty", EArgList(ELit(LUnit), EArgNil)))
}

fn build_pipe_call(stages: List<SeqStep>, input_expr: Expr) -> Expr {
    match List.first(stages) {
        None => input_expr
        Some(step) => {
            bind rest <- List.drop(stages, 1);
            match step {
                SStage(sname) => build_pipe_call(rest, ECall("", sname, EArgList(input_expr, EArgNil)))
                SPar(names) => {
                    bind names_expr <- build_par_names_expr(names);
                    bind par_call <- ECall("IO", "par_execute_raw", EArgList(names_expr, EArgList(input_expr, EArgNil)));
                    build_pipe_call(rest, par_call)
                }
            }
        }
    }
}

fn compile_seq_def(seq_def: SeqDef) -> Result<List<FnEntry>, String> {
    if seq_def.is_abstract {
        bind empty <- empty_fns();
        Result.ok(empty)
    } else {
        bind body <- build_pipe_call(seq_def.stages, EVar("$input"));
        bind fn_def <- FnDef { is_public: seq_def.is_public  name: seq_def.name  params: List.singleton(Param { name: "$input"  ty: TeSimple("Any") })  ret: TeSimple("Any")  body: body  doc: "" };
        compile_fn_def(fn_def)
    }
}

fn compile_wrapper_validator(wd: WrapperDef, items: List<Item>, acc: List<FnEntry>) -> Result<List<FnEntry>, String> {
    match wd.where_pred {
        ELambda(parts) => {
            bind param <- parts._0;
            bind body <- parts._1;
            bind err_msg <- String.concat(wd.name, ": validation failed");
            bind fn_body <- EIf(body, ECall("Result", "ok", EArgList(EVar(param), EArgNil)), ECall("Result", "err", EArgList(ELit(LStr(err_msg)), EArgNil)));
            bind fn_def <- FnDef { is_public: false  name: wd.name  params: List.singleton(Param { name: param  ty: TeSimple(wd.inner) })  ret: TeResult(TeSimple(wd.inner), TeSimple("String"))  body: fn_body  doc: "" };
            Result.and_then(compile_fn_def(fn_def), |entries| compile_items(List.drop(items, 1), List.concat(acc, entries)))
        }
        _ => Result.err(String.concat("where clause must be a lambda: ", wd.name))
    }
}

fn compile_impl_decl(id: ImplDeclDef, acc: List<FnEntry>) -> Result<List<FnEntry>, String> {
    match List.first(id.methods) {
        None => Result.ok(acc)
        Some(fn_def) => {
            bind renamed_def <- FnDef { is_public: fn_def.is_public  name: String.concat(id.type_name, String.concat("_", fn_def.name))  params: fn_def.params  ret: fn_def.ret  body: fn_def.body  doc: fn_def.doc };
            match compile_fn_def(renamed_def) {
                Err(e) => Result.err(e)
                Ok(entries) => {
                    bind remaining <- ImplDeclDef { interface_names: id.interface_names  type_name: id.type_name  methods: List.drop(id.methods, 1) };
                    compile_impl_decl(remaining, List.concat(acc, entries))
                }
            }
        }
    }
}

fn compile_items(items: List<Item>, acc: List<FnEntry>) -> Result<List<FnEntry>, String> {
    match List.first(items) {
        None => Result.ok(acc)
        Some(item) => {
            match item {
                IFn(fn_def) => {
                    Result.and_then(compile_fn_def(fn_def), |entries| compile_items(List.drop(items, 1), List.concat(acc, entries)))
                }
                IType(_) => compile_items(List.drop(items, 1), acc)
                ITest(_) => compile_items(List.drop(items, 1), acc)
                IWrapper(wd) => {
                    match wd.where_pred {
                        ELit(lit) => match lit {
                            LUnit => compile_items(List.drop(items, 1), acc)
                            _ => compile_wrapper_validator(wd, items, acc)
                        }
                        _ => compile_wrapper_validator(wd, items, acc)
                    }
                }
                IStage(stage_def) => {
                    Result.and_then(compile_stage_def(stage_def), |entries| compile_items(List.drop(items, 1), List.concat(acc, entries)))
                }
                ISeq(seq_def) => {
                    Result.and_then(compile_seq_def(seq_def), |entries| compile_items(List.drop(items, 1), List.concat(acc, entries)))
                }
                IInterface(_) => compile_items(List.drop(items, 1), acc)
                IImpl(id) => {
                    match compile_impl_decl(id, List.empty()) {
                        Err(e) => Result.err(e)
                        Ok(entries) => compile_items(List.drop(items, 1), List.concat(acc, entries))
                    }
                }
            }
        }
    }
}

fn compile(prog: Program) -> Result<Artifact, String> {
    bind init <- empty_fns();
    Result.and_then(compile_items(prog.items, init), |fns| Result.ok(Artifact { fns: fns }))
}

fn empty_str_list() -> List<String> {
    List.drop_while(List.singleton("__init__"), |v| true)
}

fn str_find_idx(strs: List<String>, target: String, idx: Int) -> Option<Int> {
    match List.first(strs) {
        None => Option.none()
        Some(s) => {
            if s == target {
                Option.some(idx)
            } else {
                str_find_idx(List.drop(strs, 1), target, idx + 1)
            }
        }
    }
}

fn intern(table: StrTable, s: String) -> InternResult {
    match str_find_idx(table.strs, s, 0) {
        Some(idx) => InternResult { table: table  idx: idx }
        None => {
            bind idx <- List.length(table.strs);
            bind new_strs <- List.push(table.strs, s);
            InternResult { table: StrTable { strs: new_strs }  idx: idx }
        }
    }
}

fn write_u32_le(n: Int) -> List<Int> {
    bind b0 <- Int.band(n, 255);
    bind b1 <- Int.band(Int.shr(n, 8), 255);
    bind b2 <- Int.band(Int.shr(n, 16), 255);
    bind b3 <- Int.band(Int.shr(n, 24), 255);
    List.push(List.push(List.push(List.singleton(b0), b1), b2), b3)
}

fn write_u16_le(n: Int) -> List<Int> {
    List.push(List.singleton(Int.band(n, 255)), Int.band(Int.shr(n, 8), 255))
}

fn write_i64_le(n: Int) -> List<Int> {
    bind b0 <- Int.band(n, 255);
    bind b1 <- Int.band(Int.shr(n, 8), 255);
    bind b2 <- Int.band(Int.shr(n, 16), 255);
    bind b3 <- Int.band(Int.shr(n, 24), 255);
    bind b4 <- Int.band(Int.shr(n, 32), 255);
    bind b5 <- Int.band(Int.shr(n, 40), 255);
    bind b6 <- Int.band(Int.shr(n, 48), 255);
    bind b7 <- Int.band(Int.shr(n, 56), 255);
    List.push(List.push(List.push(List.push(List.push(List.push(List.push(List.singleton(b0), b1), b2), b3), b4), b5), b6), b7)
}

fn write_str_bytes(s: String) -> List<Int> {
    bind bs <- String.to_bytes(s);
    bind len_bytes <- write_u32_le(List.length(bs));
    List.concat(len_bytes, bs)
}

fn write_str_table(strs: List<String>, acc: List<Int>) -> List<Int> {
    match List.first(strs) {
        None => acc
        Some(s) => {
            bind entry <- write_str_bytes(s);
            write_str_table(List.drop(strs, 1), List.concat(acc, entry))
        }
    }
}

fn write_f64_le(f: Float) -> List<Int> {
    write_i64_le(Float.to_bits(f))
}

fn serialize_const_val(cv: ConstVal) -> List<Int> {
    match cv {
        CVInt(n) => List.concat(List.singleton(1), write_i64_le(n))
        CVFloat(f) => List.concat(List.singleton(2), write_f64_le(f))
        CVStr(s) => List.concat(List.singleton(3), write_str_bytes(s))
        CVName(s) => {
            bind bs <- String.to_bytes(s);
            bind len_bytes <- write_u16_le(List.length(bs));
            List.concat(List.singleton(4), List.concat(len_bytes, bs))
        }
    }
}

fn serialize_consts(consts: List<ConstVal>, acc: List<Int>) -> List<Int> {
    match List.first(consts) {
        None => acc
        Some(cv) => {
            bind cv_bytes <- serialize_const_val(cv);
            serialize_consts(List.drop(consts, 1), List.concat(acc, cv_bytes))
        }
    }
}

fn ser_init_state() -> SerState {
    SerState { str_table: StrTable { strs: empty_str_list() }  type_bytes: empty_ints()  global_bytes: empty_ints()  fn_bytes: empty_ints()  fn_idx: 0  global_count: 0 }
}

fn process_fn_entry(entry: FnEntry, state: SerState) -> SerState {
    bind ir_name <- intern(state.str_table, entry.fname);
    bind ir_ret <- intern(ir_name.table, entry.ret_ty);
    bind ir_eff <- intern(ir_ret.table, "");
    bind type_entry <- List.concat(write_u32_le(ir_ret.idx), write_u32_le(ir_eff.idx));
    bind new_type_bytes <- List.concat(state.type_bytes, type_entry);
    bind new_global_bytes <- if entry.is_public {
        List.concat(state.global_bytes, List.concat(write_u32_le(ir_name.idx), List.concat(List.singleton(0), write_u32_le(state.fn_idx))))
    } else {
        state.global_bytes
    };
    bind new_global_count <- if entry.is_public {
        state.global_count + 1
    } else {
        state.global_count
    };
    bind const_bytes <- serialize_consts(entry.consts, empty_ints());
    bind fn_entry_bytes <- List.concat(write_u32_le(ir_name.idx), List.concat(write_u32_le(entry.arity), List.concat(write_u32_le(entry.local_count), List.concat(write_u32_le(0), List.concat(write_u32_le(ir_ret.idx), List.concat(write_u32_le(ir_eff.idx), List.concat(write_u32_le(List.length(entry.consts)), List.concat(const_bytes, List.concat(write_u32_le(List.length(entry.code)), entry.code)))))))));
    SerState { str_table: ir_eff.table  type_bytes: new_type_bytes  global_bytes: new_global_bytes  fn_bytes: List.concat(state.fn_bytes, fn_entry_bytes)  fn_idx: state.fn_idx + 1  global_count: new_global_count }
}

fn process_fn_entries(entries: List<FnEntry>, state: SerState) -> SerState {
    match List.first(entries) {
        None => state
        Some(entry) => {
            bind new_state <- process_fn_entry(entry, state);
            process_fn_entries(List.drop(entries, 1), new_state)
        }
    }
}

fn serialize_artifact(artifact: Artifact) -> List<Int> {
    bind state <- process_fn_entries(artifact.fns, ser_init_state());
    bind fn_count <- List.length(artifact.fns);
    bind str_count <- List.length(state.str_table.strs);
    bind str_bytes <- write_str_table(state.str_table.strs, empty_ints());
    bind magic <- List.push(List.push(List.push(List.singleton(70), 86), 67), 1);
    bind ver <- List.push(List.push(List.push(List.singleton(33), 0), 0), 0); // v52.2.0: 0x21
    bind header <- List.concat(List.concat(magic, ver), List.concat(List.concat(write_u32_le(str_count), write_u32_le(fn_count)), write_u32_le(state.global_count)));
    List.concat(header, List.concat(str_bytes, List.concat(state.type_bytes, List.concat(state.global_bytes, state.fn_bytes))))
}

fn spaces(n: Int) -> String {
    String.repeat(" ", n)
}

fn op_to_str(op: Op) -> String {
    match op {
        OpAdd => "+"
        OpSub => "-"
        OpMul => "*"
        OpDiv => "/"
        OpMod => "%"
        OpEq => "=="
        OpNeq => "!="
        OpLt => "<"
        OpGt => ">"
        OpLtEq => "<="
        OpGtEq => ">="
        OpAnd => "&&"
        OpOr => "||"
        OpNullCoalesce => "??"
    }
}

fn pretty_type(ty: TypeExpr) -> String {
    match ty {
        TeSimple(name) => name
        TeList(inner) => String.concat("List<", String.concat(pretty_type(inner), ">"))
        TeOption(inner) => String.concat("Option<", String.concat(pretty_type(inner), ">"))
        TeResult(parts) => String.concat("Result<", String.concat(pretty_type(parts._0), String.concat(", ", String.concat(pretty_type(parts._1), ">"))))
        TeMap(parts) => String.concat("Map<", String.concat(pretty_type(parts._0), String.concat(", ", String.concat(pretty_type(parts._1), ">"))))
        TeFn(parts) => String.concat(pretty_type(parts._0), String.concat(" -> ", pretty_type(parts._1)))
    }
}

fn pretty_pat(pat: Pat) -> String {
    match pat {
        PWild => "_"
        PVar(name) => name
        PInt(n) => Int.to_string(n)
        PFloat(f) => Float.to_string(f)
        PStr(s) => String.concat("\"", String.concat(s, "\""))
        PBool(b) => if b {
            "true"
        } else {
            "false"
        }
        PUnit => "()"
        PVariant(name) => name
        PVariantP(parts) => String.concat(parts._0, String.concat("(", String.concat(pretty_pat(parts._1), ")")))
    }
}

fn is_trivial_guard(guard: Expr) -> Bool {
    match guard {
        ELit(lit) => match lit {
            LBool(b) => b
            _ => false
        }
        _ => false
    }
}

fn is_block_expr(expr: Expr) -> Bool {
    match expr {
        EBind(parts) => true
        EBlock(parts) => true
        _ => false
    }
}

fn escape_char(c: String) -> String {
    if c == "\\" {
        "\\\\"
    } else {
        if c == "\"" {
            "\\\""
        } else {
            if c == "\n" {
                "\\n"
            } else {
                if c == "\t" {
                    "\\t"
                } else {
                    c
                }
            }
        }
    }
}

fn escape_str(s: String) -> String {
    bind chars <- String.chars(s);
    String.join(List.map(chars, |c| escape_char(c)), "")
}

fn collect_args_rev(args: Expr, acc: List<String>, indent: Int) -> List<String> {
    match args {
        EArgNil => acc
        EArgList(parts) => collect_args_rev(parts._1, List.concat(List.singleton(pretty_expr(parts._0, indent)), acc), indent)
        _ => acc
    }
}

fn pretty_args(args: Expr, indent: Int) -> String {
    String.join(collect_args_rev(args, empty_string_list(), indent), ", ")
}

fn collect_fields_rev(fields: Expr, acc: List<String>, indent: Int) -> List<String> {
    match fields {
        EFieldNil => acc
        EField(parts) => collect_fields_rev(parts._2, List.concat(List.singleton(String.concat(parts._0, String.concat(": ", pretty_expr(parts._1, indent)))), acc), indent)
        _ => acc
    }
}

fn pretty_fields_expr(fields: Expr, indent: Int) -> String {
    String.join(collect_fields_rev(fields, empty_string_list(), indent), "  ")
}

fn pretty_arm_body(expr: Expr, arm_indent: Int) -> String {
    if is_block_expr(expr) {
        String.concat("{\n", String.concat(spaces(arm_indent + 4), String.concat(pretty_expr(expr, arm_indent + 4), String.concat("\n", String.concat(spaces(arm_indent), "}")))))
    } else {
        pretty_expr(expr, arm_indent)
    }
}

fn pretty_arms(arms: Expr, indent: Int) -> String {
    match arms {
        EArmNil => ""
        EArm(parts) => {
            bind arm_indent <- indent + 4;
            bind guard_str <- if is_trivial_guard(parts._1) {
                ""
            } else {
                String.concat(" where ", pretty_expr(parts._1, arm_indent))
            };
            bind arm_line <- String.concat(spaces(arm_indent), String.concat(pretty_pat(parts._0), String.concat(guard_str, String.concat(" => ", pretty_arm_body(parts._2, arm_indent)))));
            bind rest_str <- pretty_arms(parts._3, indent);
            if rest_str == "" {
                arm_line
            } else {
                String.concat(arm_line, String.concat("\n", rest_str))
            }
        }
        _ => ""
    }
}

fn pretty_expr(expr: Expr, indent: Int) -> String {
    match expr {
        ELit(lit) => match lit {
            LInt(n) => Int.to_string(n)
            LFloat(f) => Float.to_string(f)
            LStr(s) => String.concat("\"", String.concat(escape_str(s), "\""))
            LBool(b) => if b {
                "true"
            } else {
                "false"
            }
            LUnit => "()"
        }
        EVar(name) => name
        EBinOp(parts) => String.concat(pretty_expr(parts._1, indent), String.concat(" ", String.concat(op_to_str(parts._0), String.concat(" ", pretty_expr(parts._2, indent)))))
        ECall(parts) => {
            bind fn_str <- if parts._0 == "" {
                parts._1
            } else {
                String.concat(parts._0, String.concat(".", parts._1))
            };
            String.concat(fn_str, String.concat("(", String.concat(pretty_args(parts._2, indent), ")")))
        }
        EIf(parts) => {
            String.concat("if ", String.concat(pretty_expr(parts._0, indent), String.concat(" {\n", String.concat(spaces(indent + 4), String.concat(pretty_expr(parts._1, indent + 4), String.concat("\n", String.concat(spaces(indent), String.concat("} else {\n", String.concat(spaces(indent + 4), String.concat(pretty_expr(parts._2, indent + 4), String.concat("\n", String.concat(spaces(indent), "}"))))))))))))
        }
        EAccess(parts) => String.concat(pretty_expr(parts._0, indent), String.concat(".", parts._1))
        ELambda(parts) => {
            if is_block_expr(parts._1) {
                String.concat("|", String.concat(parts._0, String.concat("| {\n", String.concat(spaces(indent + 4), String.concat(pretty_expr(parts._1, indent + 4), String.concat("\n", String.concat(spaces(indent), "}")))))))
            } else {
                String.concat("|", String.concat(parts._0, String.concat("| ", pretty_expr(parts._1, indent))))
            }
        }
        EMatch(parts) => {
            String.concat("match ", String.concat(pretty_expr(parts._0, indent), String.concat(" {\n", String.concat(pretty_arms(parts._1, indent), String.concat("\n", String.concat(spaces(indent), "}"))))))
        }
        EBlock(parts) => String.concat(pretty_expr(parts._0, indent), String.concat("\n", String.concat(spaces(indent), pretty_expr(parts._1, indent))))
        ERecordLit(parts) => String.concat(parts._0, String.concat(" { ", String.concat(pretty_fields_expr(parts._1, indent), " }")))
        EBind(parts) => {
            String.concat("bind ", String.concat(parts._0, String.concat(" <- ", String.concat(pretty_expr(parts._1, indent), String.concat("\n", String.concat(spaces(indent), pretty_expr(parts._2, indent)))))))
        }
        ECollect(inner) => {
            String.concat("collect {\n", String.concat(spaces(indent + 4), String.concat(pretty_expr(inner, indent + 4), String.concat("\n", String.concat(spaces(indent), "}")))))
        }
        EYield(inner) => String.concat("yield ", String.concat(pretty_expr(inner, indent), ";"))
        EArgList(parts) => pretty_expr(parts._0, indent)
        EArgNil => ""
        EArm(parts) => ""
        EArmNil => ""
        EField(parts) => String.concat(parts._0, String.concat(": ", pretty_expr(parts._1, indent)))
        EFieldNil => ""
        EQuestion(inner) => String.concat(pretty_expr(inner, indent), "?")
    }
}

fn pretty_param(p: Param) -> String {
    String.concat(p.name, String.concat(": ", pretty_type(p.ty)))
}

fn pretty_doc_lines(lines: List<String>, acc: String) -> String {
    match List.first(lines) {
        None => acc
        Some(line) => {
            bind rest <- List.drop(lines, 1);
            bind rendered <- String.concat("/// ", line);
            bind new_acc <- if acc == "" {
                rendered
            } else {
                String.concat(acc, String.concat("\n", rendered))
            };
            pretty_doc_lines(rest, new_acc)
        }
    }
}

fn pretty_doc(doc: String) -> String {
    if doc == "" {
        ""
    } else {
        bind lines <- String.lines(doc);
        String.concat(pretty_doc_lines(lines, ""), "\n")
    }
}

fn pretty_fn_def(f: FnDef) -> String {
    bind doc_str <- pretty_doc(f.doc);
    bind pub_str <- if f.is_public {
        "public "
    } else {
        ""
    };
    bind params_str <- String.join(List.map(f.params, |p| pretty_param(p)), ", ");
    bind ret_str <- pretty_type(f.ret);
    bind body_str <- pretty_expr(f.body, 4);
    String.concat(doc_str, String.concat(pub_str, String.concat("fn ", String.concat(f.name, String.concat("(", String.concat(params_str, String.concat(") -> ", String.concat(ret_str, String.concat(" {\n    ", String.concat(body_str, "\n}"))))))))))
}

fn pretty_variant(v: VariantDef) -> String {
    match v.payload {
        None => String.concat("| ", v.name)
        Some(ty) => String.concat("| ", String.concat(v.name, String.concat("(", String.concat(pretty_type(ty), ")"))))
    }
}

fn join_variants_loop(vs: List<VariantDef>, acc: String) -> String {
    match List.first(vs) {
        None => acc
        Some(v) => {
            bind vstr <- pretty_variant(v);
            bind rest <- List.drop(vs, 1);
            bind new_acc <- if acc == "" {
                String.concat("  ", vstr)
            } else {
                String.concat(acc, String.concat("\n  ", vstr))
            };
            join_variants_loop(rest, new_acc)
        }
    }
}

fn join_record_fields_loop(fields: List<Param>, acc: String) -> String {
    match List.first(fields) {
        None => acc
        Some(p) => {
            bind fstr <- pretty_param(p);
            bind rest <- List.drop(fields, 1);
            bind new_acc <- if acc == "" {
                String.concat("    ", fstr)
            } else {
                String.concat(acc, String.concat("\n    ", fstr))
            };
            join_record_fields_loop(rest, new_acc)
        }
    }
}

fn pretty_type_def(td: TypeDef) -> String {
    bind doc_str <- pretty_doc(td.doc);
    bind body_str <- if td.is_record {
        String.concat("type ", String.concat(td.name, String.concat(" = {\n", String.concat(join_record_fields_loop(td.fields, ""), "\n}"))))
    } else {
        String.concat("type ", String.concat(td.name, String.concat(" =\n", join_variants_loop(td.variants, ""))))
    };
    String.concat(doc_str, body_str)
}

fn pretty_test_def(td: TestDef) -> String {
    String.concat("test \"", String.concat(escape_str(td.name), String.concat("\" {\n    ", String.concat(pretty_expr(td.body, 4), "\n}"))))
}

fn pretty_effects(effects: List<String>) -> String {
    match List.first(effects) {
        None => ""
        Some(_) => String.concat(" ", String.join(List.map(effects, |e| String.concat("!", e)), " "))
    }
}

fn pretty_stage_def(sd: StageDef) -> String {
    bind doc_str <- pretty_doc(sd.doc);
    bind abs_str <- if sd.is_abstract {
        "abstract "
    } else {
        ""
    };
    bind pub_str <- if sd.is_public {
        "public "
    } else {
        ""
    };
    bind effs_str <- pretty_effects(sd.effects);
    bind sig_str <- String.concat(pub_str, String.concat(abs_str, String.concat("stage ", String.concat(sd.name, String.concat(": ", String.concat(pretty_type(sd.param_ty), String.concat(" -> ", String.concat(pretty_type(sd.ret_ty), effs_str))))))));
    bind body_str <- match sd.body {
        None => sig_str
        Some(body) => String.concat(sig_str, String.concat(" = ", pretty_expr(body, 0)))
    };
    String.concat(doc_str, body_str)
}

fn seq_step_to_string(step: SeqStep) -> String {
    match step {
        SStage(name) => name
        SPar(names) => String.concat("par [", String.concat(String.join(names, ", "), "]"))
    }
}

fn seq_steps_to_string(steps: List<SeqStep>) -> String {
    bind strs <- List.map(steps, seq_step_to_string);
    String.join(strs, " |> ")
}

fn pretty_seq_def(sd: SeqDef) -> String {
    bind doc_str <- pretty_doc(sd.doc);
    bind abs_str <- if sd.is_abstract {
        "abstract "
    } else {
        ""
    };
    bind pub_str <- if sd.is_public {
        "public "
    } else {
        ""
    };
    bind body_str <- if sd.is_abstract {
        String.concat(pub_str, String.concat(abs_str, String.concat("seq ", sd.name)))
    } else {
        bind stages_str <- seq_steps_to_string(sd.stages);
        String.concat(pub_str, String.concat(abs_str, String.concat("seq ", String.concat(sd.name, String.concat(" = ", stages_str)))))
    };
    String.concat(doc_str, body_str)
}

fn pretty_wrapper_def(wd: WrapperDef) -> String {
    bind doc_str <- pretty_doc(wd.doc);
    bind base <- String.concat("type ", String.concat(wd.name, String.concat("(", String.concat(wd.inner, ")"))));
    bind with_part <- if List.length(wd.with_impls) == 0 {
        ""
    } else {
        String.concat(" with ", String.join(wd.with_impls, ", "))
    };
    bind where_part <- match wd.where_pred {
        ELit(lit) => match lit {
            LUnit => ""
            _ => String.concat(" where ", pretty_expr(wd.where_pred, 0))
        }
        _ => String.concat(" where ", pretty_expr(wd.where_pred, 0))
    };
    String.concat(doc_str, String.concat(base, String.concat(with_part, where_part)))
}

fn pretty_item(item: Item) -> String {
    match item {
        IFn(f) => pretty_fn_def(f)
        IType(td) => pretty_type_def(td)
        ITest(td) => pretty_test_def(td)
        IStage(sd) => pretty_stage_def(sd)
        ISeq(sd) => pretty_seq_def(sd)
        IWrapper(wd) => pretty_wrapper_def(wd)
        IInterface(id) => String.concat("interface ", String.concat(id.name, " { }"))
        IImpl(id) => {
            bind iface <- match List.first(id.interface_names) {
                None => "?"
                Some(n) => n
            };
            String.concat("impl ", String.concat(iface, String.concat(" for ", String.concat(id.name, " { }"))))
        }
    }
}

fn join_items_loop(items: List<Item>, acc: String) -> String {
    match List.first(items) {
        None => acc
        Some(item) => {
            bind istr <- pretty_item(item);
            bind rest <- List.drop(items, 1);
            bind new_acc <- if acc == "" {
                istr
            } else {
                String.concat(acc, String.concat("\n\n\n", istr))
            };
            join_items_loop(rest, new_acc)
        }
    }
}

fn pretty_program(prog: Program) -> String {
    String.concat(join_items_loop(prog.items, ""), "\n")
}

public fn fmt_source(src: String) -> Result<String, String> {
    Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| Result.ok(pretty_program(prog))))
}

fn doc_fn_sig(fd: FnDef) -> String {
    bind pub_str <- if fd.is_public {
        "public "
    } else {
        ""
    };
    bind params_str <- String.join(List.map(fd.params, |p| pretty_param(p)), ", ");
    bind ret_str <- pretty_type(fd.ret);
    String.concat(pub_str, String.concat("fn ", String.concat(fd.name, String.concat("(", String.concat(params_str, String.concat(") -> ", ret_str))))))
}

fn doc_fn_def(fd: FnDef) -> String {
    if fd.is_public {
        bind sig <- doc_fn_sig(fd);
        bind doc_part <- if fd.doc == "" {
            ""
        } else {
            String.concat("\n\n", fd.doc)
        };
        String.concat("### ", String.concat(fd.name, String.concat("\n\n```\n", String.concat(sig, String.concat("\n```", doc_part)))))
    } else {
        ""
    }
}

fn doc_type_def_item(td: TypeDef) -> String {
    bind sig <- pretty_type_def(td);
    bind doc_part <- if td.doc == "" {
        ""
    } else {
        String.concat("\n\n", td.doc)
    };
    String.concat("### ", String.concat(td.name, String.concat("\n\n```\n", String.concat(sig, String.concat("\n```", doc_part)))))
}

fn doc_wrapper_def_item(wd: WrapperDef) -> String {
    bind sig <- pretty_wrapper_def(wd);
    bind doc_part <- if wd.doc == "" {
        ""
    } else {
        String.concat("\n\n", wd.doc)
    };
    String.concat("### ", String.concat(wd.name, String.concat("\n\n```\n", String.concat(sig, String.concat("\n```", doc_part)))))
}

fn doc_stage_def_item(sd: StageDef) -> String {
    if sd.is_public {
        bind sig <- pretty_stage_def(sd);
        bind doc_part <- if sd.doc == "" {
            ""
        } else {
            String.concat("\n\n", sd.doc)
        };
        String.concat("### ", String.concat(sd.name, String.concat("\n\n```\n", String.concat(sig, String.concat("\n```", doc_part)))))
    } else {
        ""
    }
}

fn doc_seq_def_item(sd: SeqDef) -> String {
    if sd.is_public {
        bind sig <- pretty_seq_def(sd);
        bind doc_part <- if sd.doc == "" {
            ""
        } else {
            String.concat("\n\n", sd.doc)
        };
        String.concat("### ", String.concat(sd.name, String.concat("\n\n```\n", String.concat(sig, String.concat("\n```", doc_part)))))
    } else {
        ""
    }
}

fn join_nonempty(items: List<String>, sep: String, acc: String) -> String {
    match List.first(items) {
        None => acc
        Some(s) => {
            bind rest <- List.drop(items, 1);
            if s == "" {
                join_nonempty(rest, sep, acc)
            } else {
                if acc == "" {
                    join_nonempty(rest, sep, s)
                } else {
                    join_nonempty(rest, sep, String.concat(acc, String.concat(sep, s)))
                }
            }
        }
    }
}

fn build_doc_section(title: String, items: List<String>) -> String {
    bind joined <- join_nonempty(items, "\n\n---\n\n", "");
    if joined == "" {
        ""
    } else {
        String.concat("## ", String.concat(title, String.concat("\n\n", joined)))
    }
}

fn build_doc_sections(fns: List<String>, types: List<String>, stages: List<String>) -> String {
    bind fn_sec <- build_doc_section("Functions", fns);
    bind type_sec <- build_doc_section("Types", types);
    bind stage_sec <- build_doc_section("Stages & Sequences", stages);
    bind parts <- List.concat(List.singleton(fn_sec), List.concat(List.singleton(type_sec), List.singleton(stage_sec)));
    join_nonempty(parts, "\n\n", "")
}

fn doc_items_acc(items: List<Item>, fns: List<String>, types: List<String>, stages: List<String>) -> String {
    match List.first(items) {
        None => build_doc_sections(fns, types, stages)
        Some(IFn(fd)) => doc_items_acc(List.drop(items, 1), List.push(fns, doc_fn_def(fd)), types, stages)
        Some(IType(td)) => doc_items_acc(List.drop(items, 1), fns, List.push(types, doc_type_def_item(td)), stages)
        Some(IWrapper(wd)) => doc_items_acc(List.drop(items, 1), fns, List.push(types, doc_wrapper_def_item(wd)), stages)
        Some(IStage(sd)) => doc_items_acc(List.drop(items, 1), fns, types, List.push(stages, doc_stage_def_item(sd)))
        Some(ISeq(sd)) => doc_items_acc(List.drop(items, 1), fns, types, List.push(stages, doc_seq_def_item(sd)))
        Some(ITest(_)) => doc_items_acc(List.drop(items, 1), fns, types, stages)
        Some(IInterface(_)) => doc_items_acc(List.drop(items, 1), fns, types, stages)
        Some(IImpl(_)) => doc_items_acc(List.drop(items, 1), fns, types, stages)
    }
}

public fn doc_source(src: String) -> Result<String, String> {
    Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| {
        bind empty_fns <- empty_string_list();
        bind empty_types <- empty_string_list();
        bind empty_stages <- empty_string_list();
        Result.ok(doc_items_acc(prog.items, empty_fns, empty_types, empty_stages))
    }))
}

fn collect_stage_names_acc(items: List<Item>, acc: List<String>) -> List<String> {
    match List.first(items) {
        None => acc
        Some(item) => {
            bind rest <- List.drop(items, 1);
            match item {
                IStage(sd) => collect_stage_names_acc(rest, List.push(acc, sd.name))
                _ => collect_stage_names_acc(rest, acc)
            }
        }
    }
}

fn collect_stage_names(prog: Program) -> List<String> {
    collect_stage_names_acc(prog.items, empty_names())
}

fn instrument_expr(e: Expr, snames: List<String>) -> Expr {
    match e {
        ELit(_) => e
        EVar(_) => e
        EArgNil => e
        EArmNil => e
        EFieldNil => e
        EBinOp(parts) => EBinOp(parts._0, instrument_expr(parts._1, snames), instrument_expr(parts._2, snames))
        ECall(parts) => {
            bind ns <- parts._0;
            bind fname <- parts._1;
            bind iargs <- instrument_expr(parts._2, snames);
            if (ns == "") && name_in_list(snames, fname) {
                ECall("Env", "profile_timed_raw", EArgList(ECall("", fname, iargs), EArgList(ECall("Env", "now_ms_raw", EArgNil), EArgList(ELit(LStr(fname)), EArgNil))))
            } else {
                ECall(ns, fname, iargs)
            }
        }
        EIf(parts) => EIf(instrument_expr(parts._0, snames), instrument_expr(parts._1, snames), instrument_expr(parts._2, snames))
        EAccess(parts) => EAccess(instrument_expr(parts._0, snames), parts._1)
        ELambda(parts) => ELambda(parts._0, instrument_expr(parts._1, snames))
        EMatch(parts) => EMatch(instrument_expr(parts._0, snames), instrument_expr(parts._1, snames))
        EBlock(parts) => EBlock(instrument_expr(parts._0, snames), instrument_expr(parts._1, snames))
        ERecordLit(parts) => ERecordLit(parts._0, instrument_expr(parts._1, snames))
        EArgList(parts) => EArgList(instrument_expr(parts._0, snames), instrument_expr(parts._1, snames))
        EArm(parts) => EArm(parts._0, instrument_expr(parts._1, snames), instrument_expr(parts._2, snames), instrument_expr(parts._3, snames))
        EBind(parts) => EBind(parts._0, instrument_expr(parts._1, snames), instrument_expr(parts._2, snames))
        ECollect(body) => ECollect(instrument_expr(body, snames))
        EYield(val_e) => EYield(instrument_expr(val_e, snames))
        EField(parts) => EField(parts._0, instrument_expr(parts._1, snames), instrument_expr(parts._2, snames))
        EQuestion(inner) => EQuestion(instrument_expr(inner, snames))
    }
}

fn instrument_item(item: Item, snames: List<String>) -> Item {
    match item {
        IFn(fd) => IFn(FnDef { is_public: fd.is_public  name: fd.name  params: fd.params  ret: fd.ret  body: instrument_expr(fd.body, snames)  doc: fd.doc })
        _ => item
    }
}

fn instrument_items_acc(items: List<Item>, snames: List<String>, acc: List<Item>) -> List<Item> {
    match List.first(items) {
        None => List.reverse(acc)
        Some(item) => instrument_items_acc(List.drop(items, 1), snames, List.push(acc, instrument_item(item, snames)))
    }
}

fn instrument_program(prog: Program, snames: List<String>) -> Program {
    Program { items: instrument_items_acc(prog.items, snames, List.empty()) }
}

public fn compile_source_profiled(src: String) -> Result<List<Int>, String> {
    Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| {
        bind snames <- collect_stage_names(prog);
        bind iprog <- instrument_program(prog, snames);
        Result.and_then(compile(iprog), |artifact| Result.ok(serialize_artifact(artifact)))
    }))
}

type LintWarning = {
    code: String
    message: String
    name: String
}

fn make_warning(code: String, name: String, msg: String) -> LintWarning {
    LintWarning { code: code  name: name  message: msg }
}

fn is_unit_type(ty: TypeExpr) -> Bool {
    match ty {
        TeSimple(name) => name == "Unit"
        _ => false
    }
}

fn lint_stage_w001(sd: StageDef) -> List<LintWarning> {
    if sd.is_abstract {
        List.empty()
    } else {
        if is_unit_type(sd.ret_ty) {
            match List.first(sd.effects) {
                Some(_) => List.empty()
                None => List.singleton(make_warning("W001", sd.name, String.concat("stage ", String.concat(sd.name, " の戻り型が Unit ですがエフェクトがありません"))))
            }
        } else {
            List.empty()
        }
    }
}

fn find_stage_by_name(name: String, items: List<Item>) -> Option<StageDef> {
    match List.first(items) {
        None => Option.none()
        Some(item) => {
            match item {
                IStage(sd) => if sd.name == name {
                    Option.some(sd)
                } else {
                    find_stage_by_name(name, List.drop(items, 1))
                }
                _ => find_stage_by_name(name, List.drop(items, 1))
            }
        }
    }
}

fn seq_step_last_stage_name(step: SeqStep) -> Option<String> {
    match step {
        SStage(n) => Option.some(n)
        SPar(names) => List.last(names)
    }
}

fn lint_seq_w002(sd: SeqDef, items: List<Item>) -> List<LintWarning> {
    if sd.is_abstract {
        List.empty()
    } else {
        match List.last(sd.stages) {
            None => List.empty()
            Some(last_step) => match seq_step_last_stage_name(last_step) {
                None => List.empty()
                Some(last_name) => match find_stage_by_name(last_name, items) {
                    None => List.empty()
                    Some(sd_fnd) => match List.first(sd_fnd.effects) {
                        Some(_) => List.empty()
                        None => List.singleton(make_warning("W002", sd.name, String.concat("seq ", String.concat(sd.name, " の最終 stage にエフェクトがありません"))))
                    }
                }
            }
        }
    }
}

fn pat_binds_name(pat: Pat, name: String) -> Bool {
    match pat {
        PVar(n) => n == name
        PVariantP(parts) => pat_binds_name(parts._1, name)
        _ => false
    }
}

fn expr_uses(name: String, expr: Expr) -> Bool {
    match expr {
        EVar(n) => n == name
        ELit(_) => false
        EArgNil => false
        EArmNil => false
        EFieldNil => false
        EBinOp(parts) => expr_uses(name, parts._1) || expr_uses(name, parts._2)
        ECall(parts) => expr_uses(name, parts._2)
        EIf(parts) => (expr_uses(name, parts._0) || expr_uses(name, parts._1)) || expr_uses(name, parts._2)
        EAccess(parts) => expr_uses(name, parts._0)
        ELambda(parts) => if parts._0 == name {
            false
        } else {
            expr_uses(name, parts._1)
        }
        EMatch(parts) => expr_uses(name, parts._0) || expr_uses(name, parts._1)
        EBlock(parts) => expr_uses(name, parts._0) || expr_uses(name, parts._1)
        ERecordLit(parts) => expr_uses(name, parts._1)
        EArgList(parts) => expr_uses(name, parts._0) || expr_uses(name, parts._1)
        EArm(parts) => if pat_binds_name(parts._0, name) {
            expr_uses(name, parts._3)
        } else {
            (expr_uses(name, parts._1) || expr_uses(name, parts._2)) || expr_uses(name, parts._3)
        }
        EBind(parts) => if parts._0 == name {
            expr_uses(name, parts._1)
        } else {
            expr_uses(name, parts._1) || expr_uses(name, parts._2)
        }
        ECollect(inner) => expr_uses(name, inner)
        EYield(inner) => expr_uses(name, inner)
        EField(parts) => expr_uses(name, parts._1) || expr_uses(name, parts._2)
        EQuestion(inner) => expr_uses(name, inner)
    }
}

fn lint_expr_w003(expr: Expr) -> List<LintWarning> {
    match expr {
        EBind(parts) => List.concat(if parts._0 == "_" {
            List.empty()
        } else {
            if expr_uses(parts._0, parts._2) {
                List.empty()
            } else {
                List.singleton(make_warning("W003", parts._0, String.concat("変数 ", String.concat(parts._0, " は定義されていますが使用されていません"))))
            }
        }, List.concat(lint_expr_w003(parts._1), lint_expr_w003(parts._2)))
        EIf(parts) => List.concat(lint_expr_w003(parts._1), lint_expr_w003(parts._2))
        EMatch(parts) => List.concat(lint_expr_w003(parts._0), lint_expr_w003(parts._1))
        EArm(parts) => List.concat(lint_expr_w003(parts._2), lint_expr_w003(parts._3))
        EBlock(parts) => List.concat(lint_expr_w003(parts._0), lint_expr_w003(parts._1))
        ELambda(parts) => lint_expr_w003(parts._1)
        ECollect(inner) => lint_expr_w003(inner)
        _ => List.empty()
    }
}

fn is_wild_pat(pat: Pat) -> Bool {
    match pat {
        PWild => true
        PVar(n) => n == "_"
        _ => false
    }
}

fn is_wildcard_only(arms: Expr) -> Bool {
    match arms {
        EArmNil => false
        EArm(parts) => match parts._3 {
            EArmNil => is_wild_pat(parts._0)
            _ => false
        }
        _ => false
    }
}

fn lint_arms_w005(arms: Expr) -> List<LintWarning> {
    match arms {
        EArmNil => List.empty()
        EArm(parts) => List.concat(lint_expr_w005(parts._2), lint_arms_w005(parts._3))
        _ => List.empty()
    }
}

fn lint_expr_w005(expr: Expr) -> List<LintWarning> {
    match expr {
        EMatch(parts) => List.concat(if is_wildcard_only(parts._1) {
            List.singleton(make_warning("W005", "_", "match 式の腕が _ のみです。網羅的なパターンを検討してください"))
        } else {
            List.empty()
        }, List.concat(lint_expr_w005(parts._0), lint_arms_w005(parts._1)))
        EIf(parts) => List.concat(lint_expr_w005(parts._1), lint_expr_w005(parts._2))
        EBlock(parts) => List.concat(lint_expr_w005(parts._0), lint_expr_w005(parts._1))
        EBind(parts) => List.concat(lint_expr_w005(parts._1), lint_expr_w005(parts._2))
        ELambda(parts) => lint_expr_w005(parts._1)
        ECollect(inner) => lint_expr_w005(inner)
        EArm(parts) => List.concat(lint_expr_w005(parts._2), lint_expr_w005(parts._3))
        _ => List.empty()
    }
}

fn lint_fn_w004(fd: FnDef) -> List<LintWarning> {
    bind n <- List.length(fd.params);
    if n >= 4 {
        List.singleton(make_warning("W004", fd.name, String.concat("fn ", String.concat(fd.name, String.concat(" の引数が ", String.concat(Int.to_string(n), " 個です。レコード型へのまとめを検討してください"))))))
    } else {
        List.empty()
    }
}

fn lint_arms_w007(arms: Expr, depth: Int) -> List<LintWarning> {
    match arms {
        EArmNil => List.empty()
        EArm(parts) => List.concat(lint_fn_w007(parts._2, depth), lint_arms_w007(parts._3, depth))
        _ => List.empty()
    }
}

fn lint_fn_w007(expr: Expr, depth: Int) -> List<LintWarning> {
    match expr {
        EMatch(parts) => if depth >= 3 {
            List.singleton(make_warning("W007", "_", String.concat("deeply nested match (depth ", String.concat(Int.to_string(depth), ")\n  = help: extract inner logic into a helper function\n  = help: consider using Result.and_then / Option.map to flatten\n  = note: deeply nested match reduces readability and can cause compiler issues"))))
        } else {
            List.concat(lint_fn_w007(parts._0, depth), lint_arms_w007(parts._1, depth + 1))
        }
        EBind(parts) => List.concat(lint_fn_w007(parts._1, depth), lint_fn_w007(parts._2, depth))
        EIf(parts) => List.concat(lint_fn_w007(parts._1, depth), lint_fn_w007(parts._2, depth))
        EBlock(parts) => List.concat(lint_fn_w007(parts._0, depth), lint_fn_w007(parts._1, depth))
        ELambda(parts) => lint_fn_w007(parts._1, 1)
        ECollect(inner) => lint_fn_w007(inner, depth)
        _ => List.empty()
    }
}

fn lint_fn(fd: FnDef) -> List<LintWarning> {
    List.concat(lint_fn_w004(fd), List.concat(lint_expr_w003(fd.body), List.concat(lint_expr_w005(fd.body), lint_fn_w007(fd.body, 1))))
}

fn lint_stage(sd: StageDef) -> List<LintWarning> {
    match sd.body {
        None => lint_stage_w001(sd)
        Some(body) => List.concat(lint_stage_w001(sd), List.concat(lint_expr_w003(body), List.concat(lint_expr_w005(body), lint_fn_w007(body, 1))))
    }
}

fn lint_item(item: Item, items: List<Item>) -> List<LintWarning> {
    match item {
        IFn(fd) => lint_fn(fd)
        IStage(sd) => lint_stage(sd)
        ISeq(sd) => lint_seq_w002(sd, items)
        _ => List.empty()
    }
}

fn lint_items_loop(items: List<Item>, all_items: List<Item>) -> List<LintWarning> {
    match List.first(items) {
        None => List.empty()
        Some(item) => List.concat(lint_item(item, all_items), lint_items_loop(List.drop(items, 1), all_items))
    }
}

fn lint_all(prog: Program) -> List<LintWarning> {
    lint_items_loop(prog.items, prog.items)
}

fn format_warning(w: LintWarning) -> String {
    String.concat(w.code, String.concat(":", String.concat(w.name, String.concat(":", w.message))))
}

fn format_warnings_loop(ws: List<LintWarning>, acc: String) -> String {
    match List.first(ws) {
        None => acc
        Some(w) => format_warnings_loop(List.drop(ws, 1), if acc == "" {
            format_warning(w)
        } else {
            String.concat(acc, String.concat("\n", format_warning(w)))
        })
    }
}

fn format_warnings(ws: List<LintWarning>) -> String {
    format_warnings_loop(ws, "")
}

public fn lint_source(src: String) -> Result<String, String> {
    Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| Result.ok(format_warnings(lint_all(prog)))))
}

public fn compile_bytes_from_src(src: String) -> Result<List<Int>, String> {
    Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| Result.and_then(compile(prog), |artifact| Result.ok(serialize_artifact(artifact)))))
}

fn compile_file_quiet(ctx: CommonCtx, path: String) -> Result<Artifact, String> {
    Result.and_then(ctx.io.read_file_raw(path), |src| Result.and_then(lex(src), |toks| Result.and_then(parse_tokens(toks), |prog| compile(prog))))
}

fn print_bytes(ctx: CommonCtx, bytes: List<Int>) -> Bool {
    match List.first(bytes) {
        None => true
        Some(b) => {
            bind _ <- ctx.io.println(Int.to_string(b));
            print_bytes(ctx, List.drop(bytes, 1))
        }
    }
}

public fn main(ctx: AppCtx) -> Bool {
    bind args <- ctx.io.argv();
    match List.first(args) {
        None => {
            bind _ <- ctx.io.println("usage: compiler <file.fav>");
            false
        }
        Some(path) => {
            match compile_file_quiet(ctx, path) {
                Err(e) => {
                    bind _ <- ctx.io.println(String.concat("error: ", e));
                    false
                }
                Ok(artifact) => {
                    bind bytes <- serialize_artifact(artifact);
                    bind _ <- ctx.io.println(String.concat("compiled: ", Int.to_string(List.length(bytes))));
                    print_bytes(ctx, bytes)
                }
            }
        }
    }
}

test "compile_bytes_from_src handles empty source gracefully" {
    match compile_bytes_from_src("") {
        Ok(_) => true
        Err(_) => true
    }
}

test "lex and parse hello.fav source" {
    bind src <- "fn add(a: Int, b: Int) -> Int { a + b }";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => List.length(prog.items) == 1
            }
        }
    }
}

test "full pipeline on simple fn produces non-empty bytecode" {
    bind src <- "fn add(a: Int, b: Int) -> Int { a + b } public fn main() -> Bool { true }";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => {
                    match compile(prog) {
                        Err(_) => false
                        Ok(artifact) => List.length(artifact.fns) > 0
                    }
                }
            }
        }
    }
}

test "lex stage keyword" {
    match lex("stage") {
        Err(_) => false
        Ok(toks) => {
            match List.first(toks) {
                Some(TkStage) => true
                _ => false
            }
        }
    }
}

test "lex seq keyword" {
    match lex("seq") {
        Err(_) => false
        Ok(toks) => {
            match List.first(toks) {
                Some(TkSeq) => true
                _ => false
            }
        }
    }
}

test "lex abstract keyword" {
    match lex("abstract") {
        Err(_) => false
        Ok(toks) => {
            match List.first(toks) {
                Some(TkAbstract) => true
                _ => false
            }
        }
    }
}

test "parse stage def" {
    bind src <- "stage Double: Int -> Int = |n| { n * 2 }";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => List.length(prog.items) == 1
            }
        }
    }
}

test "parse seq def" {
    bind src <- "stage Double: Int -> Int = |n| { n * 2 } stage AddOne: Int -> Int = |n| { n + 1 } seq Pipeline = Double |> AddOne";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => List.length(prog.items) == 3
            }
        }
    }
}

test "compile stage def produces fn entry" {
    bind src <- "stage Double: Int -> Int = |n| { n * 2 }";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => {
                    match compile(prog) {
                        Err(_) => false
                        Ok(artifact) => List.length(artifact.fns) == 1
                    }
                }
            }
        }
    }
}

test "compile seq def produces fn entries" {
    bind src <- "stage Double: Int -> Int = |n| { n * 2 } stage AddOne: Int -> Int = |n| { n + 1 } seq Pipeline = Double |> AddOne";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => {
                    match compile(prog) {
                        Err(_) => false
                        Ok(artifact) => List.length(artifact.fns) == 3
                    }
                }
            }
        }
    }
}

test "parse abstract stage" {
    bind src <- "abstract stage Transform: Int -> Int";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => List.length(prog.items) == 1
            }
        }
    }
}

test "compile abstract stage produces no fn entry" {
    bind src <- "abstract stage Transform: Int -> Int";
    match lex(src) {
        Err(_) => false
        Ok(toks) => {
            match parse_tokens(toks) {
                Err(_) => false
                Ok(prog) => {
                    match compile(prog) {
                        Err(_) => false
                        Ok(artifact) => List.length(artifact.fns) == 0
                    }
                }
            }
        }
    }
}
