import rune "aws"

type TxnRow = {
  transaction_id: String
  amount:         Float
  region:         String
  category:       String
}

fn read_txn_csv(path: String) -> List<TxnRow> !IO {
  bind text <- IO.read_file_raw(path)
  match Csv.parse_raw(text, ",", true) {
    Err(_) => List.empty()
    Ok(raw) =>
      match Schema.adapt(raw, "TxnRow") {
        Err(_) => List.empty()
        Ok(rows) => rows
      }
  }
}

stage LoadAll: List<String> -> List<TxnRow> !IO = |paths| {
  bind jan <- read_txn_csv(List.nth(paths, 0))
  bind feb <- read_txn_csv(List.nth(paths, 1))
  bind mar <- read_txn_csv(List.nth(paths, 2))
  bind total <- List.length(jan) + List.length(feb) + List.length(mar)
  bind _ <- IO.println(String.concat("[INFO] Loaded ", String.concat(Int.to_string(total), " rows")))
  List.concat(List.concat(jan, feb), mar)
}

stage Validate: List<TxnRow> -> List<TxnRow> !IO = |rows| {
  bind valid <- List.filter(rows, |row|
    if row.amount == 0.0 { false }
    else { if row.amount < 0.0 { false }
           else { if row.amount < 10.0 { false }
                  else { if row.region == "" { false } else { true } } } }
  )
  bind total <- List.length(rows)
  bind n_valid <- List.length(valid)
  bind n_drop <- total - n_valid
  bind _ <- IO.println(String.concat("[INFO] Valid: ", String.concat(Int.to_string(n_valid), String.concat("/", String.concat(Int.to_string(total), String.concat(" | Dropped: ", Int.to_string(n_drop)))))))
  valid
}

stage WriteOutput: List<TxnRow> -> Unit !IO !AWS = |rows| {
  bind _ <- IO.println(String.concat("[INFO] Writing ", String.concat(Int.to_string(List.length(rows)), " rows to S3")))
  bind payload <- Json.encode_raw(rows)
  aws.s3_put_json("favnir-e2e-demo/airgap/output/summary.json", rows)
}

seq AnalyzePipeline = LoadAll |> Validate |> WriteOutput
