import "parquet"

type Product = { id: Int name: String }

fn row(id: String, name: String) -> Map<String, String> {
    Map.set(Map.set((), "id", id), "name", name)
}

test "parquet_write_returns_ok" {
    bind rows <- collect { yield row("1", "Alice"); () }
    bind result <- parquet.write("../fav/tmp/test_product.parquet", "Product", rows)
    assert(Result.is_ok(result))
}

test "parquet_read_after_write_count" {
    bind rows <- collect { yield row("1", "Alice"); yield row("2", "Bob"); () }
    bind _ <- parquet.write("../fav/tmp/test_count.parquet", "Product", rows)
    bind result <- parquet.read("../fav/tmp/test_count.parquet")
    match result {
        Ok(loaded) => assert_eq(List.length(loaded), 2)
        Err(_)     => assert(false)
    }
}

test "parquet_read_preserves_string_field" {
    bind rows <- collect { yield row("1", "Alice"); () }
    bind _ <- parquet.write("../fav/tmp/test_name.parquet", "Product", rows)
    bind result <- parquet.read("../fav/tmp/test_name.parquet")
    match result {
        Ok(loaded) => {
            bind first <- Option.unwrap_or(List.first(loaded), ())
            assert_eq(Option.unwrap_or(Map.get(first, "name"), ""), "Alice")
        }
        Err(_) => assert(false)
    }
}

test "parquet_read_missing_file_is_err" {
    bind result <- parquet.read("../fav/tmp/missing.parquet")
    assert(Result.is_err(result))
}

test "parquet_row_count_matches_write" {
    bind rows <- collect { yield row("1", "Alice"); yield row("2", "Bob"); yield row("3", "Carol"); () }
    bind _ <- parquet.write("../fav/tmp/test_row_count.parquet", "Product", rows)
    bind count <- parquet.row_count("../fav/tmp/test_row_count.parquet")
    assert_eq(Result.unwrap_or(count, -1), 3)
}

test "parquet_append_increases_count" {
    bind rows1 <- collect { yield row("1", "Alice"); () }
    bind rows2 <- collect { yield row("2", "Bob"); () }
    bind _ <- parquet.write("../fav/tmp/test_append.parquet", "Product", rows1)
    bind _ <- parquet.append("../fav/tmp/test_append.parquet", "Product", rows2)
    bind count <- parquet.row_count("../fav/tmp/test_append.parquet")
    assert_eq(Result.unwrap_or(count, -1), 2)
}

test "parquet_write_empty_rows" {
    bind empty <- collect { () }
    bind result <- parquet.write("../fav/tmp/test_empty.parquet", "Product", empty)
    assert(Result.is_ok(result))
}
