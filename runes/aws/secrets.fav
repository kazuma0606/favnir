// runes/aws/secrets.fav — AWS Secrets Manager wrapper (v14.4.0)
// ctx: AwsCtx (String JSON from Ctx.build_aws_raw) — region field is extracted automatically.

/// Retrieve a secret value from AWS Secrets Manager.
/// `ctx` is an AwsCtx value (String) — region is extracted via Ctx.aws_get_field_raw.
/// `secret_name` is the secret's name or ARN.
public fn secrets_get(ctx: String, secret_name: String) -> Result<String, String> {
    AWS.secrets_get_raw(Ctx.aws_get_field_raw(ctx, "region"), secret_name)
}
