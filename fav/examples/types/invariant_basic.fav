type Age = {
    value: Int
    invariant value >= 0
    invariant value <= 150
}

public fn main(ctx: AppCtx) -> Unit {
    bind ok_age <- Age.new(30)
    match ok_age {
        ok(age) => ctx.io.println_int(age.value)
        err(msg) => ctx.io.println(Debug.show(msg))
    };

    bind bad_age <- Age.new(-1)
    match bad_age {
        ok(age) => ctx.io.println_int(age.value)
        err(msg) => ctx.io.println(Debug.show(msg))
    }
}
