type UserRow = {
    value: Int
}

abstract trf ParseRow: Int -> UserRow
abstract trf SaveRow: UserRow -> String

abstract flw DataPipeline<Row> {
    parse: Int -> Row
    save: Row -> String
}

trf ParseUser: Int -> UserRow = |x| {
    UserRow { value: x }
}

trf SaveUser: UserRow -> String = |row| {
    "saved"
}

flw UserImport = DataPipeline<UserRow> {
    parse <- ParseUser
    save <- SaveUser
}

public fn main() -> String {
    UserImport(1)
}
