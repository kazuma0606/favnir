fn fizzbuzz(n: Int) -> String {
  match (n % 3 == 0, n % 5 == 0) {
    (true, true)   => "FizzBuzz"
    (true, false)  => "Fizz"
    (false, true)  => "Buzz"
    _              => Int.to_string(n)
  }
}

public fn main() -> Unit !Io {
  IO.println(List.join(List.map(List.range(1, 16), fizzbuzz), "\n"))
}
