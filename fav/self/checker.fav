// Favnir self-hosted type checker
// v7.8.0: generics (TyVar / Subst / unify / parameterized builtin inference)

// ── Mirrored AST types (from parser.fav) ─────────────────────────────────────

type Lit =
  | LInt(Int)
  | LFloat(Float)
  | LStr(String)
  | LBool(Bool)
  | LUnit

type Op =
  | OpAdd
  | OpSub
  | OpMul
  | OpDiv
  | OpMod
  | OpEq
  | OpNeq
  | OpLt
  | OpGt
  | OpLtEq
  | OpGtEq
  | OpAnd
  | OpOr
  | OpNullCoalesce

type Pat =
  | PWild
  | PVar(String)
  | PInt(Int)
  | PFloat(Float)
  | PStr(String)
  | PBool(Bool)
  | PUnit
  | PVariant(String)
  | PVariantP(String, Pat)

type Expr =
  | ELit(Lit)
  | EVar(String)
  | EBinOp(Op, Expr, Expr)
  | ECall(String, String, Expr)
  | EIf(Expr, Expr, Expr)
  | EAccess(Expr, String)
  | ELambda(String, Expr)
  | EMatch(Expr, Expr)
  | EBlock(Expr, Expr)
  | ERecordLit(String, Expr)
  | EArgList(Expr, Expr)
  | EArgNil
  | EArm(Pat, Expr, Expr)
  | EArmNil
  | EBind(String, Expr, Expr)
  | EField(String, Expr, Expr)
  | EFieldNil
  | EQuestion(Expr)

type TypeExpr =
  | TeSimple(String)
  | TeList(TypeExpr)
  | TeOption(TypeExpr)
  | TeResult(TypeExpr, TypeExpr)
  | TeMap(TypeExpr, TypeExpr)
  | TeFn(TypeExpr, TypeExpr)

type Param = {
    name: String
    ty: TypeExpr
}

type FnDef = {
    is_public: Bool
    name: String
    params: List<Param>
    ret: TypeExpr
    effects: List<String>
    body: Expr
}

type VariantDef = {
    name: String
    payload: Option<TypeExpr>
}

type TypeDef = {
    name: String
    is_record: Bool
    type_params: List<String>
    variants: List<VariantDef>
    fields: List<Param>
}

type TestDef = {
    name: String
    body: Expr
}

type WrapperDef = {
    name: String
    inner: String
    has_where: Bool
    with_impls: List<String>
}

type Item =
  | IFn(FnDef)
  | IType(TypeDef)
  | ITest(TestDef)
  | IWrapper(WrapperDef)

type Program = {
    items: List<Item>
}

// ── Type sum type ─────────────────────────────────────────────────────────────

type Type =
  | TyInt
  | TyFloat
  | TyBool
  | TyString
  | TyUnit
  | TyList(Type)
  | TyOption(Type)
  | TyResult(Type, Type)
  | TyMap(Type, Type)
  | TyFn(Type, Type)
  | TyUnknown
  | TyVar(String)

fn type_to_str(ty: Type) -> String {
    match ty {
        TyInt => "Int"
        TyFloat => "Float"
        TyBool => "Bool"
        TyString => "String"
        TyUnit => "Unit"
        TyList(t) => String.concat("List<", String.concat(type_to_str(t), ">"))
        TyOption(t) => String.concat("Option<", String.concat(type_to_str(t), ">"))
        TyResult(a, b) => "Result"
        TyMap(k, v) => "Map"
        TyFn(a, b) => "Fn"
        TyUnknown => "Unknown"
        TyVar(name) => name
    }
}

fn str_to_type(s: String) -> Type {
    if s == "Int" { TyInt }
    else {
    if s == "Float" { TyFloat }
    else {
    if s == "Bool" { TyBool }
    else {
    if s == "String" { TyString }
    else {
    if s == "Unit" { TyUnit }
    else { TyUnknown }
    }}}}
}

// ── Environment (association list) ────────────────────────────────────────────

type KVPair = {
    first: String
    second: String
}

type CheckState = {
    env: List<KVPair>
    errors: List<String>
}

type InfState = {
    subst:   List<KVPair>
    counter: Int
}

type InfResult = {
    ty:      String
    subst:   List<KVPair>
    counter: Int
}

fn env_empty() -> List<KVPair> {
    List.take_while(List.singleton(KVPair { first: "", second: "" }), |v| false)
}

fn env_insert(env: List<KVPair>, name: String, ty: String) -> List<KVPair> {
    List.push(env, KVPair { first: name, second: ty })
}

fn env_lookup(env: List<KVPair>, name: String) -> Option<String> {
    match List.first(env) {
        None => Option.none()
        Some(pair) => {
            if pair.first == name { Option.some(pair.second) }
            else { env_lookup(List.drop(env, 1), name) }
        }
    }
}

// ── Substitution environment (type variables) ─────────────────────────────────

fn subst_empty() -> List<KVPair> { env_empty() }

fn subst_insert(subst: List<KVPair>, name: String, ty: String) -> List<KVPair> {
    env_insert(subst, name, ty)
}

fn subst_lookup(subst: List<KVPair>, name: String) -> Option<String> {
    env_lookup(subst, name)
}

// ── TypeExpr to string ────────────────────────────────────────────────────────

fn type_expr_to_str(te: TypeExpr) -> String {
    match te {
        TeSimple(name) => name
        TeList(inner) => String.concat("List<", String.concat(type_expr_to_str(inner), ">"))
        TeOption(inner) => String.concat("Option<", String.concat(type_expr_to_str(inner), ">"))
        TeResult(a, b) => "Result"
        TeMap(k, v) => "Map"
        TeFn(a, b) => "Fn"
    }
}

// ── Error code formatting ─────────────────────────────────────────────────────

fn fmt_err(code: String, msg: String) -> String {
    String.concat(code, String.concat(": ", msg))
}

// ── Literal inference ─────────────────────────────────────────────────────────

fn infer_lit(lit: Lit) -> String {
    match lit {
        LInt(n) => "Int"
        LFloat(f) => "Float"
        LStr(s) => "String"
        LBool(b) => "Bool"
        LUnit => "Unit"
    }
}

// ── Binary operator type inference ────────────────────────────────────────────

fn is_arith_op(op: Op) -> Bool {
    match op {
        OpAdd => true
        OpSub => true
        OpMul => true
        OpDiv => true
        OpMod => true
        _ => false
    }
}

fn is_cmp_op(op: Op) -> Bool {
    match op {
        OpEq => true
        OpNeq => true
        OpLt => true
        OpGt => true
        OpLtEq => true
        OpGtEq => true
        _ => false
    }
}

fn is_null_coalesce_op(op: Op) -> Bool {
    match op {
        OpNullCoalesce => true
        _ => false
    }
}

fn infer_op(op: Op, lty: String, rty: String) -> Result<String, String> {
    if is_arith_op(op) {
        if lty == "Int" && rty == "Int" { Result.ok("Int") }
        else {
        if lty == "Float" && rty == "Float" { Result.ok("Float") }
        else {
        if lty == "Unknown" || rty == "Unknown" { Result.ok("Unknown") }
        else { Result.err(fmt_err("E0001", String.concat("arithmetic type mismatch: ", String.concat(lty, String.concat(" vs ", rty))))) }
        }}
    } else {
    if is_cmp_op(op) {
        Result.ok("Bool")
    } else {
    if is_null_coalesce_op(op) {
        // lhs is Option<T>, rhs is T; result is T (approximate with rhs type)
        Result.ok(rty)
    } else {
        if lty == "Bool" && rty == "Bool" { Result.ok("Bool") }
        else {
        if lty == "Unknown" || rty == "Unknown" { Result.ok("Bool") }
        else { Result.err(fmt_err("E0002", "logical operator requires Bool operands")) }
        }
    }}}
}

