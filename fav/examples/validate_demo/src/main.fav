import "validate"

public fn main(ctx: AppCtx) -> Unit {
    bind r1 <- validate.Required("Alice")
    ctx.io.println($"Required('Alice'): {Debug.show(r1)}");

    bind r2 <- validate.Required("")
    ctx.io.println($"Required(''): {Debug.show(r2)}");

    bind r3 <- validate.MinLen(3)("hi")
    ctx.io.println($"MinLen(3)('hi'): {Debug.show(r3)}");

    bind r4 <- validate.Email("alice@example.com")
    ctx.io.println($"Email('alice@example.com'): {Debug.show(r4)}");

    bind r5 <- validate.Email("notanemail")
    ctx.io.println($"Email('notanemail'): {Debug.show(r5)}");

    bind v1 <- validate.Required("hi")
    bind v2 <- validate.MinLen(5)("hi")
    bind v3 <- validate.MaxLen(10)("hi")
    bind combined <- validate.all_pass("hi")(collect { yield v1; yield v2; yield v3; })
    ctx.io.println($"all_pass('hi', [Required,MinLen5,MaxLen10]): {Debug.show(combined)}")
}
