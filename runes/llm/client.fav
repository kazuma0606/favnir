// runes/llm/client.fav — LLM クライアント (v9.6.0)
// Anthropic Claude / OpenAI 統一 API。エフェクトは !Llm。
//
// 環境変数:
//   LLM_PROVIDER  = "anthropic"（デフォルト）| "openai"
//   LLM_MODEL     = モデル名（省略時: claude-opus-4-6 / gpt-4o）
//   ANTHROPIC_API_KEY / OPENAI_API_KEY

// complete — シングルターンプロンプトを LLM に送信
public fn complete(prompt: String) -> Result<String, String> {
    Llm.complete_raw(prompt)
}

// chat — マルチターン会話を LLM に送信
// messages は [{role: "user"|"assistant", content: "..."}] の JSON 文字列
public fn chat(messages_json: String) -> Result<String, String> {
    Llm.chat_raw(messages_json)
}

// extract<T> — プロンプトとデータから型 T の構造体を抽出
public fn extract<T>(prompt: String, data: String) -> Result<T, String> {
    match Llm.extract_raw(type_name_of<T>(), prompt, data) {
        Err(e) => Result.err(e)
        Ok(raw) =>
            match Json.parse_raw(raw) {
                Err(e) => Result.err(String.concat("llm.extract: ", e))
                Ok(parsed) =>
                    match Schema.adapt_one(parsed, type_name_of<T>()) {
                        Err(_) => Result.err("llm.extract: schema error")
                        Ok(v)  => Result.ok(v)
                    }
            }
    }
}

// stream — ストリーミングレスポンス（v38.7.0: collect-all 実装）
public fn stream(prompt: String) -> Result<String, String> {
    Llm.stream_raw(prompt)
}

// function_call — ツール呼び出し
// tools_json は [{"name": "...", "description": "...", "parameters": {...}}] の JSON 文字列
public fn function_call(prompt: String, tools_json: String) -> Result<String, String> {
    Llm.function_call_raw(prompt, tools_json)
}

// embed — テキストをベクトル化（LLM_PROVIDER=openai 専用）
// 戻り値は JSON 配列文字列 "[0.1, 0.2, ...]"
public fn embed(text: String) -> Result<String, String> {
    Llm.embed_raw(text)
}
