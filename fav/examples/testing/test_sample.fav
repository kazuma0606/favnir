// test_sample.fav — example tests using the `test` keyword
// Run with: fav test examples/test_sample.fav

test "arithmetic: add" {
    assert_eq(1 + 2, 3)
}

test "arithmetic: subtract" {
    assert_eq(10 - 3, 7)
}

test "string concat" {
    assert_eq(String.concat("hello", " world"), "hello world")
}

test "list operations" {
    bind xs <- List.range(1, 6)
    assert_eq(List.length(xs), 5);
    assert(List.any(xs, |x| x > 3));
    assert(List.all(xs, |x| x > 0))
}

test "option some is_some" {
    assert(Option.is_some(Option.some(42)))
}

test "option none is_none" {
    assert(Option.is_none(Option.none()))
}

test "result ok unwrap" {
    bind r <- Result.ok(99)
    assert_eq(Result.unwrap_or(r, 0), 99)
}

test "result err unwrap_or" {
    bind r <- Result.err("oops")
    assert_eq(Result.unwrap_or(r, -1), -1)
}

test "string length" {
    assert_eq(String.length("hello"), 5)
}

test "debug show int" {
    assert_eq(Debug.show(42), "42")
}

// Uncomment to see a failure report:
// test "intentional failure" {
//     assert_eq(1, 2)
// }
